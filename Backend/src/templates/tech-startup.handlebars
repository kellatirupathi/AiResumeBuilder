<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{firstName}} {{lastName}} - Resume</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    @page {
      size: A4;
      margin: 15mm 0 15mm 0;
    }
    @page :first {
      margin-top: 0;
    }

    /* Pagination — fill page 1 first, then continue naturally on page 2 */
    /* Only keep small inline atoms intact (pills/badges) */
    .skill-tag, .skill-pill, .skill-item,
    .item-date-badge, .job-date, .grade-badge, .cert-date-badge, .cert-date {
      page-break-inside: avoid;
      break-inside: avoid;
    }
    /* Allow column cells to break across pages so content flows naturally */
    .left-column, .right-column,
    .main-column, .side-column,
    .main-left, .main-right,
    .sidebar, .main-content {
      page-break-inside: auto;
      break-inside: auto;
    }
    p, li {
      orphans: 3;
      widows: 3;
    }

    * {
      box-sizing: border-box;
    }

    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
      line-height: 1.5;
      color: #333;
      margin: 0;
      padding: 0;
      background-color: #ffffff;
    }

    .resume {
      width: 210mm;
      margin: 0;
      padding: 0;
      background-color: #ffffff;
      box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
      /* overflow:hidden REMOVED — was preventing pagination */
    }

    .header {
      padding: 1rem;
      border-bottom: 1px solid {{themeColor}}30;
    }

    .header-content {
      display: table;
      width: 100%;
      table-layout: fixed;
    }

    .header-left,
    .header-right {
      display: table-cell;
      vertical-align: top;
    }

    .header-left {
      width: 63%;
      padding-right: 1rem;
    }

    .header-right {
      width: 37%;
    }

    .name {
      font-size: 1.5rem;
      font-weight: 700;
      margin: 0 0 0.25rem;
      color: {{themeColor}};
    }

    .job-title {
      font-size: 0.875rem;
      font-weight: 500;
      margin: 0 0 0.5rem;
      color: #374151;
    }

    .summary {
      max-width: 36rem;
      margin-top: 0.25rem;
      font-size: 13px;                     /* between text-xs (12px) and text-sm (14px) */
      color: #374151;
    }

    .summary p {
      margin: 0;
    }

    .contact-box {
      padding: 0.75rem;
      border-radius: 0.375rem;
      background-color: #f9fafb;
    }

    .contact-info {
      font-size: 0.875rem;
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
    }

    .contact-item {
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .contact-icon {
      width: 1rem;
      height: 1rem;
      color: {{themeColor}};
      flex: 0 0 auto;
      fill: none;
      stroke: currentColor;
      stroke-width: 1.5;
      stroke-linecap: round;
      stroke-linejoin: round;
    }

    .social-item {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.875rem;
      color: {{themeColor}};
      word-break: break-all;
    }

    .social-icon {
      flex-shrink: 0;
      width: 1rem;
      height: 1rem;
      color: {{themeColor}};
    }

    .social-item a {
      color: {{themeColor}};
      text-decoration: none;
    }

    .social-item a:hover {
      text-decoration: underline;
    }

    .main-content {
      padding: 1rem;
    }

    .section,
    .additional-section-container {
      margin-bottom: 0.75rem;
    }

    .section-title {
      font-size: 1.125rem;
      font-weight: 500;
      margin: 0 0 0.5rem;
      padding-bottom: 0.25rem;
      border-bottom: 1px solid {{themeColor}}30;
      color: {{themeColor}};
    }

    .skills-container {
      display: flex;
      flex-wrap: wrap;
      gap: 0.25rem;
    }

    .skill-tag {
      background-color: {{themeColor}}15;
      color: {{themeColor}};
      font-size: 0.875rem;
      padding: 0.25rem 0.5rem;
      border-radius: 0.375rem;
    }

    .experience-container,
    .projects-container,
    .education-container,
    .certifications-container {
      display: block;
    }

    .experience-container > * + *,
    .projects-container > * + *,
    .education-container > * + *,
    .certifications-container > * + * {
      margin-top: 0.5rem;
    }

    .experience-item,
    .project-item,
    .education-item,
    .certification-item {
      border-left: 2px solid {{themeColor}};
      padding-left: 0.75rem;
      padding-bottom: 0.25rem;
      /* page-break-inside: avoid removed — items can split so page 1 fills first */
    }

    .experience-header,
    .project-header,
    .education-header,
    .certification-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      flex-wrap: wrap;
      margin-bottom: 0.25rem;
      gap: 0.5rem;
    }

    .experience-title,
    .project-title,
    .education-degree {
      font-size: 1rem;
      font-weight: 500;
      margin: 0;
      color: #111827;
    }

    .certification-title {
      font-size: 1rem;
      font-weight: 500;
      margin: 0;
      color: {{themeColor}};
    }

    .experience-date,
    .education-date,
    .certification-date {
      font-size: 0.75rem;
      color: #6b7280;
      white-space: nowrap;
    }

    .experience-company {
      font-size: 0.875rem;
      color: #374151;
      margin: 0 0 0.25rem;
    }

    .education-university {
      font-size: 0.875rem;
      font-weight: 500;
      color: #374151;
      margin: 0;
    }

    .certification-issuer {
      font-size: 0.875rem;
      color: #374151;
      margin: 0;
    }

    /* Experience & Project descriptions reduced to text-xs; additional sections kept at text-sm */
    .additional-section-content {
      font-size: 0.875rem;                 /* text-sm */
      color: #4b5563;
    }
    .experience-description,
    .project-description {
      font-size: 13px;
      line-height: 1.4;
      color: #4b5563;
    }

    .experience-description ul.bullet-list,
    .project-description ul.bullet-list {
      padding-left: 4px;
      margin: 5px 0 5px 16px;
      list-style: disc;
      font-size: 13px;
      line-height: 1.4;
    }

    .experience-description ul.bullet-list li,
    .project-description ul.bullet-list li {
      margin-bottom: 4px;
    }

    .experience-description ul.bullet-list li::marker,
    .project-description ul.bullet-list li::marker {
      color: #555;
    }

    .project-links {
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .project-link {
      display: flex;
      align-items: center;
      gap: 0.125rem;
      font-size: 0.75rem;
      color: #4b5563;
      text-decoration: none;
    }

    .project-link.demo-link {
      color: #2563eb;
    }

    .certification-link {
      display: flex;
      align-items: center;
      gap: 0.25rem;
      font-size: 0.75rem;
      color: {{themeColor}};
      text-decoration: none;
    }

    .project-link-icon,
    .certification-link-icon {
      width: 0.75rem;
      height: 0.75rem;
      flex: 0 0 auto;
    }

    .project-tech {
      font-size: 0.75rem;
      color: #6b7280;
      margin-bottom: 0.25rem;
    }

    .tech-label {
      font-weight: 500;
    }

    .education-details,
    .certification-details {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 0.5rem;
    }

    .education-grade {
      font-size: 0.75rem;
      color: #4b5563;
    }

    .education-description {
      font-size: 0.75rem;
      color: #4b5563;
      margin-top: 0.25rem;
    }

    .additional-section-content ul {
      padding-left: 1.5rem;
      margin: 0;
    }

    .additional-section-content li {
      margin-bottom: 0.25rem;
    }

    @media print {
      .resume {
        box-shadow: none;
      }

      .header-content {
        display: table !important;
        width: 100% !important;
      }

      .header-left,
      .header-right {
        display: table-cell !important;
        vertical-align: top !important;
      }
    }
  </style>
</head>
<body>
  <div class="resume">
    <div class="header">
      <div class="header-content">
        <div class="header-left">
          <h1 class="name">{{firstName}} {{lastName}}</h1>
          {{#if jobTitle}}
            <h2 class="job-title">{{jobTitle}}</h2>
          {{/if}}

          {{#if summary}}
            <div class="summary">
              <p>{{summary}}</p>
            </div>
          {{/if}}
        </div>

        <div class="header-right">
          <div class="contact-box">
            <div class="contact-info">
              {{#if email}}
                <div class="contact-item">
                  <svg class="contact-icon" viewBox="0 0 24 24">
                    <path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                  <span>{{email}}</span>
                </div>
              {{/if}}

              {{#if phone}}
                <div class="contact-item">
                  <svg class="contact-icon" viewBox="0 0 24 24">
                    <path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  </svg>
                  <span>{{phone}}</span>
                </div>
              {{/if}}

              {{#if address}}
                <div class="contact-item">
                  <svg class="contact-icon" viewBox="0 0 24 24">
                    <path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                  <span>{{address}}</span>
                </div>
              {{/if}}

              {{#if githubUrl}}
                <div class="social-item">
                  <svg class="social-icon" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                  </svg>
                  <a href="{{formatUrl githubUrl}}" target="_blank" rel="noopener noreferrer">{{formatUrl githubUrl}}</a>
                </div>
              {{/if}}

              {{#if linkedinUrl}}
                <div class="social-item">
                  <svg class="social-icon" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M4.98 3.5c0 1.381-1.11 2.5-2.48 2.5s-2.48-1.119-2.48-2.5c0-1.38 1.11-2.5 2.48-2.5s2.48 1.12 2.48 2.5zm.02 4.5h-5v16h5v-16zm7.982 0h-4.968v16h4.969v-8.399c0-4.67 6.029-5.052 6.029 0v8.399h4.988v-10.131c0-7.88-8.922-7.593-11.018-3.714v-2.155z"/>
                  </svg>
                  <a href="{{formatUrl linkedinUrl}}" target="_blank" rel="noopener noreferrer">{{formatUrl linkedinUrl}}</a>
                </div>
              {{/if}}

              {{#if portfolioUrl}}
                <div class="social-item">
                  <svg class="social-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
                  </svg>
                  <a href="{{formatUrl portfolioUrl}}" target="_blank" rel="noopener noreferrer">{{formatUrl portfolioUrl}}</a>
                </div>
              {{/if}}
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="main-content">
      {{#if skills.length}}
        <div class="section">
          <h3 class="section-title">Skills</h3>
          <div class="skills-container">
            {{#each skills}}
              <div class="skill-tag">{{this.name}}</div>
            {{/each}}
          </div>
        </div>
      {{/if}}

      {{#if experience.length}}
        <div class="section">
          <h3 class="section-title">Experience</h3>
          <div class="experience-container">
            {{#each experience}}
              <div class="experience-item">
                <div class="experience-header">
                  <h4 class="experience-title">{{this.title}}</h4>
                  <span class="experience-date">
                    {{this.startDate}}{{#if this.startDate}}{{#if this.currentlyWorking}} - Present{{else}}{{#if this.endDate}} - {{this.endDate}}{{/if}}{{/if}}{{/if}}
                  </span>
                </div>
                <h5 class="experience-company">
                  {{this.companyName}}{{#if this.city}}{{#if this.companyName}}, {{/if}}{{this.city}}{{/if}}{{#if this.state}}{{#if this.city}}, {{/if}}{{this.state}}{{/if}}
                </h5>
                {{#if this.workSummary}}
                  <div class="experience-description">{{{bulletList this.workSummary}}}</div>
                {{/if}}
              </div>
            {{/each}}
          </div>
        </div>
      {{/if}}

      {{#if projects.length}}
        <div class="section">
          <h3 class="section-title">Projects</h3>
          <div class="projects-container">
            {{#each projects}}
              <div class="project-item">
                <div class="project-header">
                  <h4 class="project-title">{{this.projectName}}</h4>
                  <div class="project-links">
                    {{#if this.githubLink}}
                      <a href="{{formatUrl this.githubLink}}" target="_blank" rel="noopener noreferrer" class="project-link">
                        <svg class="project-link-icon" viewBox="0 0 24 24" fill="currentColor">
                          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                        </svg>
                        Code
                      </a>
                    {{/if}}
                    {{#if this.deployedLink}}
                      <a href="{{formatUrl this.deployedLink}}" target="_blank" rel="noopener noreferrer" class="project-link demo-link">
                        <svg class="project-link-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                        </svg>
                        Demo
                      </a>
                    {{/if}}
                  </div>
                </div>
                {{#if this.techStack}}
                  <div class="project-tech">
                    <span class="tech-label">Tech Stack: </span>{{this.techStack}}
                  </div>
                {{/if}}
                {{#if this.projectSummary}}
                  <div class="project-description">{{{bulletList this.projectSummary}}}</div>
                {{/if}}
              </div>
            {{/each}}
          </div>
        </div>
      {{/if}}

      {{#if education.length}}
        <div class="section">
          <h3 class="section-title">Education</h3>
          <div class="education-container">
            {{#each education}}
              <div class="education-item">
                <div class="education-header">
                  <h4 class="education-degree">
                    {{this.degree}}{{#if this.major}}{{#if this.degree}} in {{/if}}{{this.major}}{{/if}}
                  </h4>
                  <span class="education-date">
                    {{this.startDate}}{{#if this.startDate}}{{#if this.endDate}} - {{/if}}{{/if}}{{this.endDate}}
                  </span>
                </div>
                <div class="education-details">
                  <h5 class="education-university">{{this.universityName}}</h5>
                  {{#if this.grade}}
                    <div class="education-grade">{{this.gradeType}}: {{this.grade}}</div>
                  {{/if}}
                </div>
                {{#if this.description}}
                  <p class="education-description">{{this.description}}</p>
                {{/if}}
              </div>
            {{/each}}
          </div>
        </div>
      {{/if}}

      {{#if certifications.length}}
        <div class="section">
          <h3 class="section-title">Certifications</h3>
          <div class="certifications-container">
            {{#each certifications}}
              <div class="certification-item">
                <div class="certification-header">
                  <h4 class="certification-title">{{this.name}}</h4>
                  {{#if this.date}}
                    <span class="certification-date">{{this.date}}</span>
                  {{/if}}
                </div>
                <div class="certification-details">
                  <h5 class="certification-issuer">{{this.issuer}}</h5>
                  {{#if this.credentialLink}}
                    <a href="{{formatUrl this.credentialLink}}" target="_blank" rel="noopener noreferrer" class="certification-link">
                      <svg class="certification-link-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101" />
                        <path d="M10.172 13.828a4 4 0 005.656 0l4-4a4 4 0 10-5.656-5.656l-1.102 1.101" />
                      </svg>
                      View
                    </a>
                  {{/if}}
                </div>
              </div>
            {{/each}}
          </div>
        </div>
      {{/if}}

      {{#if additionalSections.length}}
        {{#each additionalSections}}
          <div class="additional-section-container">
            <h3 class="section-title">{{this.title}}</h3>
            <div class="additional-section-content">{{{this.content}}}</div>
          </div>
        {{/each}}
      {{/if}}
    </div>
  </div>
</body>
</html>
