<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{firstName}} {{lastName}}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    /* Base Styles */
    @page {
      size: A4;
      margin: 15mm 0 15mm 0;
    }
    @page :first {
      margin-top: 0;
    }

    /* Pagination — fill page 1 first, then continue naturally on page 2 */
    /* Only keep small inline atoms intact (pills/badges) */
    .skill-tag, .skill-pill, .skill-item,
    .item-date-badge, .job-date, .grade-badge, .cert-date-badge, .cert-date {
      page-break-inside: avoid;
      break-inside: avoid;
    }
    /* Allow column cells to break across pages so content flows naturally */
    .left-column, .right-column,
    .main-column, .side-column,
    .main-left, .main-right,
    .sidebar, .main-content {
      page-break-inside: auto;
      break-inside: auto;
    }
    p, li {
      orphans: 3;
      widows: 3;
    }

    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
      line-height: 1.4;
      color: #333;
      margin: 0;
      padding: 0;
      background-color: white;
    }

    .resume {
      width: 210mm;
      margin: 0;
      padding: 0;
      background-color: white;
      box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
      border-radius: 0.375rem;
      /* overflow:hidden REMOVED — was preventing pagination (created atomic block formatting context) */
    }

    /* Header Section (frontend: pt-4 + px-6 on inner row) */
    .header {
      padding: 1rem 0 0 0;
    }

    /* Inline-block layout (NOT table) so each side takes its NATURAL height.
       table-cells in the same row stretch to match — that was making the contact card
       extend down to match the long summary on the left. */
    .header-container {
      display: block;
      width: 100%;
      padding: 0 1.5rem;
      box-sizing: border-box;
      font-size: 0;                /* removes whitespace gap between inline-blocks */
    }

    .name-container {
      display: inline-block;
      width: 65%;
      vertical-align: top;
      box-sizing: border-box;
      padding-right: 1rem;
      font-size: 1rem;             /* restore for content */
    }

    .name {
      font-size: 2.25rem;          /* text-4xl */
      font-weight: 700;
      letter-spacing: -0.025em;
      margin: 0 0 0.25rem 0;
      color: #111827;
    }

    .job-title {
      font-size: 1.25rem;          /* text-xl */
      font-weight: 500;
      color: #4b5563;              /* text-gray-600 */
      margin: 0 0 0.75rem 0;       /* mb-3 */
    }

    .summary {
      max-width: 42rem;            /* max-w-2xl */
      padding-right: 1rem;         /* pr-4 */
      margin-bottom: 0.25rem;      /* mb-1 */
    }

    .summary-text {
      font-size: 12px;
      color: #4b5563;
      line-height: 1.5;
      margin: 0;
    }

    /* Contact box: inline-block so it takes NATURAL height (matches frontend) */
    .contact-container {
      display: inline-block;
      width: 35%;
      vertical-align: top;
      box-sizing: border-box;
      padding: 1rem 1.25rem;       /* px-5 py-4 */
      margin-bottom: 1rem;
      border-radius: 0.25rem;
      text-align: right;
      background-color: {{themeColor}}14;  /* ~8% alpha */
      font-size: 1rem;             /* restore from font-size:0 on parent */
    }

    .contact-list {
      display: block;
    }
    .contact-list > * + * {
      margin-top: 0.5rem;          /* space-y-2 */
    }

    .contact-item {
      display: flex;
      align-items: center;
      justify-content: flex-end;
      font-size: 0.875rem;         /* text-sm */
      gap: 0.5rem;                 /* gap-2 */
    }

    .contact-text {
      color: #374151;              /* text-gray-700 */
    }

    .contact-icon {
      width: 1rem;                 /* h-4 w-4 */
      height: 1rem;
      color: {{themeColor}};
      flex-shrink: 0;
    }

    .social-links {
      display: flex;
      justify-content: flex-end;
      gap: 0.75rem;                /* gap-3 */
      margin-top: 0.75rem;         /* mt-3 */
    }

    .social-link {
      color: {{themeColor}};
      text-decoration: none;
    }

    .social-icon {
      width: 1.25rem;              /* h-5 w-5 */
      height: 1.25rem;
    }

    /* TWO-COLUMN LAYOUT that paginates correctly:
       - .left-column is a normal block element that flows across pages naturally
       - .right-column is position:absolute → renders ONLY on page 1, doesn't block left column's pagination
       - Container .main-content is position:relative so .right-column anchors to its top-right
       - Result: Page 1 shows both columns side-by-side; page 2+ continues left-column's overflow */
    .main-content {
      padding: 0.25rem 1rem 1rem 1rem;
      display: block;
      width: 100%;
      box-sizing: border-box;
      position: relative;
    }

    .left-column {
      display: block;
      width: 66.6667%;             /* md:col-span-8 */
      padding-right: 0.25rem;      /* half of gap-2 */
      box-sizing: border-box;
    }

    .right-column {
      position: absolute;
      top: 0.25rem;                /* matches .main-content padding-top */
      right: 1rem;                 /* matches .main-content padding-right */
      width: calc(33.3333% - 1rem);
      padding-left: 0.25rem;
      box-sizing: border-box;
    }

    .left-column-inner,
    .right-column-inner {
      display: block;
    }
    .left-column-inner > * + *,
    .right-column-inner > * + * {
      margin-top: 0.5rem;          /* space-y-2 */
    }

    /* Section Styling */
    .section-title {
      font-size: 1.25rem;          /* text-xl */
      font-weight: 700;
      margin: 0 0 0.25rem 0;       /* mb-1 */
      color: {{themeColor}};
    }

    .section-title-uppercase {
      text-transform: uppercase;
    }

    /* Item containers (frontend: space-y-1.5 / space-y-4) */
    .experience-container,
    .certifications-container,
    .education-container {
      display: block;
    }
    .experience-container > * + *,
    .certifications-container > * + *,
    .education-container > * + * {
      margin-top: 0.375rem;        /* space-y-1.5 */
    }

    .projects-container {
      display: block;
    }
    .projects-container > * + * {
      margin-top: 1rem;            /* space-y-4 */
    }

    .additional-container {
      display: block;
    }
    .additional-container > * + * {
      margin-top: 0.25rem;
    }

    /* CARDS — frontend wraps every item in p-2 rounded-md with themeColor 05 bg */
    /* Items can break across pages — content fills page 1 first */
    .experience-item,
    .certification-item,
    .education-item,
    .additional-item {
      padding: 0.5rem;             /* p-2 */
      background-color: {{themeColor}}0D;  /* ~5% alpha */
      border-radius: 0.375rem;     /* rounded-md */
    }

    /* Project items use a bottom border separator instead of a card */
    .project-item {
      margin-bottom: 0.5rem;       /* mb-2 */
      padding-bottom: 0.5rem;
      border-bottom: 1px solid {{themeColor}}1A;  /* ~10% alpha */
    }
    .project-item:last-child {
      border-bottom: none;
      margin-bottom: 0;
      padding-bottom: 0;
    }

    .experience-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 0.25rem;      /* mb-1 */
    }

    .job-title-text {
      font-size: 1rem;             /* text-base */
      font-weight: 700;
      color: #1f2937;              /* text-gray-800 */
      margin: 0;
    }

    .job-date {
      font-size: 0.75rem;          /* text-xs */
      font-weight: 500;
      padding: 0.25rem 0.75rem;    /* px-3 py-1 */
      border-radius: 0.25rem;
      background-color: {{themeColor}}33;  /* 20 alpha */
      color: {{themeColor}};
      white-space: nowrap;
    }

    .company {
      font-size: 0.875rem;         /* text-sm */
      font-weight: 500;
      color: #374151;              /* text-gray-700 */
      margin: 0 0 0.25rem 0;       /* mb-1 */
    }

    /* Bullet lists for experience & projects (output from bulletList helper) */
    .bullet-list {
      list-style: disc;
      padding-left: 4px;
      margin: 5px 0 5px 16px;
      color: #4b5563;              /* text-gray-600 */
      font-size: 13px;
      line-height: 1.4;
    }
    .bullet-list li {
      margin-bottom: 4px;
    }
    .bullet-list li:last-child {
      margin-bottom: 0;
    }
    .bullet-list li::marker {
      color: #555;
    }

    .project-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 0.25rem;      /* mb-1 */
    }

    .project-title {
      font-size: 1rem;             /* text-base */
      font-weight: 700;
      color: #1f2937;
      margin: 0;
    }

    .project-links {
      display: flex;
      gap: 0.5rem;                 /* gap-2 */
    }

    .project-link {
      display: flex;
      align-items: center;
      gap: 0.25rem;
      font-size: 0.75rem;          /* text-xs */
      padding: 0.125rem 0.5rem;    /* px-2 py-0.5 */
      border-radius: 0.25rem;
      background-color: {{themeColor}}26;  /* ~15% alpha */
      color: {{themeColor}};
      text-decoration: none;
    }

    .project-link-icon {
      width: 0.75rem;              /* h-3 w-3 */
      height: 0.75rem;
    }

    .project-tech {
      display: inline-block;
      font-size: 0.75rem;          /* text-xs */
      font-family: monospace;
      color: {{themeColor}};
      margin: 0 0 0.25rem 0;       /* mb-1 */
    }

    /* Certification — frontend has 2 horizontal rows */
    .cert-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .cert-title {
      font-size: 1rem;             /* text-base */
      font-weight: 700;
      color: #1f2937;              /* text-gray-800 */
      margin: 0;
    }

    .cert-issuer {
      font-size: 0.875rem;         /* text-sm */
      font-weight: 500;
      color: #374151;              /* text-gray-700 */
      margin: 0;
    }

    .cert-date {
      font-size: 0.75rem;          /* text-xs */
      font-weight: 500;
      padding: 0.25rem 0.75rem;    /* px-3 py-1 */
      border-radius: 0.25rem;
      background-color: {{themeColor}}33;  /* 20 alpha */
      color: {{themeColor}};
      white-space: nowrap;
    }

    .cert-link {
      display: flex;
      align-items: center;
      gap: 0.375rem;               /* gap-1.5 */
      font-size: 0.75rem;          /* text-xs */
      color: {{themeColor}};
      text-decoration: none;
    }
    .cert-link:hover { text-decoration: underline; }

    .cert-link-icon {
      width: 0.875rem;             /* h-3.5 w-3.5 */
      height: 0.875rem;
    }

    /* Skills — alternating subtle bg using THEME color, not hardcoded blue */
    .skills-container {
      display: block;
    }
    .skills-container > * + * {
      margin-top: 0.25rem;         /* space-y-1 */
    }

    .skill-item {
      display: flex;
      align-items: center;
      padding: 0.5rem;             /* p-2 */
      border-radius: 0.375rem;     /* rounded-md */
    }
    .skill-item-even { background-color: {{themeColor}}0D; }   /* themeColor 05 */
    .skill-item-odd  { background-color: {{themeColor}}1A; }   /* themeColor 10 */

    .skill-dot {
      width: 0.5rem;               /* w-2 h-2 */
      height: 0.5rem;
      border-radius: 0.125rem;     /* rounded-sm */
      margin-right: 0.5rem;        /* mr-2 */
      background-color: {{themeColor}};
      flex-shrink: 0;
    }

    .skill-name {
      font-size: 0.875rem;         /* text-sm */
      color: #374151;              /* text-gray-700 */
    }

    /* Education */
    .degree {
      font-size: 0.875rem;         /* text-sm */
      font-weight: 700;
      color: {{themeColor}};
      margin: 0 0 0.125rem 0;      /* mb-0.5 */
    }

    .school {
      font-size: 0.875rem;         /* text-sm */
      font-weight: 500;
      color: #374151;              /* text-gray-700 */
      margin: 0 0 0.125rem 0;      /* mb-0.5 */
    }

    .education-details {
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: 0.75rem;          /* text-xs */
      color: #6b7280;              /* text-gray-500 */
      margin-bottom: 0.125rem;     /* mb-0.5 */
    }

    .grade {
      padding: 0.125rem 0.5rem;    /* px-2 py-0.5 */
      border-radius: 0.375rem;     /* rounded-md */
      background-color: {{themeColor}}26;  /* ~15% alpha */
      color: {{themeColor}};
      font-size: 0.75rem;
    }

    .education-description {
      font-size: 0.75rem;          /* text-xs */
      color: #4b5563;              /* text-gray-600 */
      margin: 0.125rem 0 0 0;
    }

    /* Additional sections (right column) */
    .additional-content {
      font-size: 0.875rem;         /* text-sm */
      color: #4b5563;
      line-height: 1.625;
    }
    .additional-content p { margin: 0 0 0.25rem 0; }
    .additional-content p:last-child { margin-bottom: 0; }

    @media print {
      .resume { box-shadow: none; border-radius: 0; }
      .header-container { display: block !important; width: 100% !important; font-size: 0 !important; }
      .name-container,
      .contact-container { display: inline-block !important; vertical-align: top !important; font-size: 1rem !important; }
      /* Two-column with absolute right column for print — left column paginates naturally */
      .main-content {
        display: block !important;
        width: 100% !important;
        position: relative !important;
      }
      .left-column {
        display: block !important;
        width: 66.6667% !important;
        padding-right: 0.25rem !important;
        box-sizing: border-box !important;
      }
      .right-column {
        position: absolute !important;
        top: 1rem !important;
        right: 1rem !important;
        width: calc(33.3333% - 1rem) !important;
        padding-left: 0.25rem !important;
        box-sizing: border-box !important;
      }
    }
  </style>
</head>
<body>
  <div class="resume">
    <!-- Header Section -->
    <div class="header">
      <div class="header-container">
        <div class="name-container">
          <h1 class="name">{{firstName}} {{lastName}}</h1>
          {{#if jobTitle}}<h2 class="job-title">{{jobTitle}}</h2>{{/if}}
          {{#if summary}}<div class="summary"><p class="summary-text">{{summary}}</p></div>{{/if}}
        </div>

        <div class="contact-container">
          <div class="contact-list">
            {{#if email}}
              <div class="contact-item">
                <span class="contact-text">{{email}}</span>
                <svg class="contact-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
              </div>
            {{/if}}
            {{#if phone}}
              <div class="contact-item">
                <span class="contact-text">{{phone}}</span>
                <svg class="contact-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
              </div>
            {{/if}}
            {{#if address}}
              <div class="contact-item">
                <span class="contact-text">{{address}}</span>
                <svg class="contact-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
              </div>
            {{/if}}
          </div>

          <div class="social-links">
            {{#if linkedinUrl}}
              <a href="{{formatUrl linkedinUrl}}" target="_blank" rel="noopener noreferrer" class="social-link"><svg class="social-icon" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24"><path d="M4.98 3.5c0 1.381-1.11 2.5-2.48 2.5s-2.48-1.119-2.48-2.5c0-1.38 1.11-2.5 2.48-2.5s2.48 1.12 2.48 2.5zm.02 4.5h-5v16h5v-16zm7.982 0h-4.968v16h4.969v-8.399c0-4.67 6.029-5.052 6.029 0v8.399h4.988v-10.131c0-7.88-8.922-7.593-11.018-3.714v-2.155z"/></svg></a>
            {{/if}}
            {{#if githubUrl}}
              <a href="{{formatUrl githubUrl}}" target="_blank" rel="noopener noreferrer" class="social-link"><svg class="social-icon" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg></a>
            {{/if}}
            {{#if portfolioUrl}}
              <a href="{{formatUrl portfolioUrl}}" target="_blank" rel="noopener noreferrer" class="social-link"><svg class="social-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" /></svg></a>
            {{/if}}
          </div>
        </div>
      </div>
    </div>

    <!-- Main Content -->
    <div class="main-content">
      <!-- Left Column -->
      <div class="left-column">
        <div class="left-column-inner">

          {{#if experience.length}}
            <div class="section">
              <h3 class="section-title">EXPERIENCE</h3>
              <div class="experience-container">
                {{#each experience}}
                  <div class="experience-item">
                    <div class="experience-header">
                      <h4 class="job-title-text">{{this.title}}</h4>
                      <span class="job-date">{{this.startDate}}{{#if this.startDate}}{{#if (or this.endDate this.currentlyWorking)}} - {{/if}}{{/if}}{{#if this.currentlyWorking}}Present{{else}}{{this.endDate}}{{/if}}</span>
                    </div>
                    <h5 class="company">{{this.companyName}}{{#if this.city}}{{#if this.companyName}}, {{/if}}{{this.city}}{{/if}}{{#if this.state}}{{#if this.city}}, {{/if}}{{this.state}}{{/if}}</h5>
                    {{{bulletList this.workSummary}}}
                  </div>
                {{/each}}
              </div>
            </div>
          {{/if}}

          {{#if projects.length}}
            <div class="section">
              <h3 class="section-title">PROJECTS</h3>
              <div class="projects-container">
                {{#each projects}}
                  <div class="project-item">
                    <div class="project-header">
                      <h4 class="project-title">{{this.projectName}}</h4>
                      <div class="project-links">
                        {{#if this.githubLink}}
                          <a href="{{formatUrl this.githubLink}}" target="_blank" rel="noopener noreferrer" class="project-link"><svg class="project-link-icon" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>Code</a>
                        {{/if}}
                        {{#if this.deployedLink}}
                          <a href="{{formatUrl this.deployedLink}}" target="_blank" rel="noopener noreferrer" class="project-link"><svg class="project-link-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>Live Demo</a>
                        {{/if}}
                      </div>
                    </div>
                    {{#if this.techStack}}<div class="project-tech">{{this.techStack}}</div>{{/if}}
                    {{{bulletList this.projectSummary}}}
                  </div>
                {{/each}}
              </div>
            </div>
          {{/if}}

        </div>
      </div>

      <!-- Right Column -->
      <div class="right-column">
        <div class="right-column-inner">

          {{#if skills.length}}
            <div class="section">
              <h3 class="section-title">SKILLS</h3>
              <div class="skills-container">
                {{#each skills}}
                  <div class="skill-item {{#if_even @index}}skill-item-even{{else}}skill-item-odd{{/if_even}}">
                    <div class="skill-dot"></div>
                    <span class="skill-name">{{this.name}}</span>
                  </div>
                {{/each}}
              </div>
            </div>
          {{/if}}

          {{#if education.length}}
            <div class="section">
              <h3 class="section-title">EDUCATION</h3>
              <div class="education-container">
                {{#each education}}
                  <div class="education-item">
                    <h4 class="degree">{{this.degree}}{{#if this.major}}{{#if this.degree}} in {{/if}}{{this.major}}{{/if}}</h4>
                    <h5 class="school">{{this.universityName}}</h5>
                    <div class="education-details">
                      <span>{{this.startDate}}{{#if this.startDate}}{{#if this.endDate}} - {{this.endDate}}{{/if}}{{/if}}</span>
                      {{#if this.grade}}<span class="grade">{{this.gradeType}}: {{this.grade}}</span>{{/if}}
                    </div>
                    {{#if this.description}}<p class="education-description">{{this.description}}</p>{{/if}}
                  </div>
                {{/each}}
              </div>
            </div>
          {{/if}}

          {{#if certifications.length}}
            <div class="section">
              <h3 class="section-title">CERTIFICATIONS</h3>
              <div class="certifications-container">
                {{#each certifications}}
                  <div class="certification-item">
                    <div class="cert-row">
                      <h4 class="cert-title">{{this.name}}</h4>
                      {{#if this.date}}<span class="cert-date">{{this.date}}</span>{{/if}}
                    </div>
                    <div class="cert-row">
                      <h5 class="cert-issuer">{{this.issuer}}</h5>
                      {{#if this.credentialLink}}
                        <a href="{{formatUrl this.credentialLink}}" target="_blank" rel="noopener noreferrer" class="cert-link">
                          <svg class="cert-link-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101" />
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.172 13.828a4 4 0 005.656 0l4-4a4 4 0 10-5.656-5.656l-1.102 1.101" />
                          </svg>
                          View
                        </a>
                      {{/if}}
                    </div>
                  </div>
                {{/each}}
              </div>
            </div>
          {{/if}}

          {{#if additionalSections.length}}
            {{#each additionalSections}}
              <div class="section">
                <h3 class="section-title section-title-uppercase">{{this.title}}</h3>
                <div class="additional-item">
                  <div class="additional-content">{{{this.content}}}</div>
                </div>
              </div>
            {{/each}}
          {{/if}}

        </div>
      </div>
    </div>
  </div>
</body>
</html>
