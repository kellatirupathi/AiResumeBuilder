<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{firstName}} {{lastName}}</title>
  <style>
    @page {
      size: A4;
      margin: 0;
    }

    * {
      box-sizing: border-box;
    }

    html,
    body {
      margin: 0;
      padding: 0;
      background: #ffffff;
    }

    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
      color: #111827;
      line-height: 1.5;
    }

    .resume {
      width: 210mm;
      margin: 0;
      padding: 0;
      background: #ffffff;
      border-radius: 6px;
      overflow: hidden;
      box-shadow: 0 20px 25px -5px rgba(15, 23, 42, 0.08), 0 8px 10px -6px rgba(15, 23, 42, 0.08);
    }

    .header {
      position: relative;
    }

    .header-card {
      margin: 1rem 1.5rem 0;
      padding: 0.75rem 1.5rem;
      background: #ffffff;
      border-radius: 0.75rem;
      box-shadow: 0 10px 15px -3px rgba(15, 23, 42, 0.1), 0 4px 6px -4px rgba(15, 23, 42, 0.1);
      display: table;
      width: calc(100% - 3rem);
      table-layout: fixed;
    }

    .header-identity {
      display: table-cell;
      width: 58%;
      vertical-align: middle;
    }

    .header-name {
      margin: 0;
      font-size: 1.5rem;
      line-height: 1.2;
      font-weight: 700;
      letter-spacing: -0.025em;
      color: #111827;
    }

    .header-title {
      margin: 0.35rem 0 0;
      font-size: 1.125rem;
      line-height: 1.3;
      font-weight: 300;
      color: {{themeColor}};
    }

    .contact-badges {
      display: table-cell;
      width: 42%;
      vertical-align: middle;
      text-align: right;
      white-space: normal;
    }

    .contact-badges-inner {
      display: inline-grid;
      grid-template-columns: auto auto;
      justify-content: end;
      gap: 0.25rem;
      max-width: 100%;
    }

    .contact-badge-address {
      grid-column: 1 / -1;
      justify-self: end;
    }

    .contact-badge {
      display: inline-flex;
      align-items: center;
      padding: 0.25rem 0.75rem;
      border-radius: 9999px;
      background: {{themeColorTransparent10}};
      font-size: 0.75rem;
      line-height: 1;
      color: #111827;
      white-space: nowrap;
    }

    .badge-icon {
      width: 0.75rem;
      height: 0.75rem;
      margin-right: 0.25rem;
      flex: 0 0 auto;
      stroke: {{themeColor}};
      fill: none;
      stroke-width: 2;
      stroke-linecap: round;
      stroke-linejoin: round;
    }

    .main-content {
      margin-top: 1rem;
      padding: 0 1.5rem 1rem;
    }

    .social-links {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 0.75rem;
      margin-bottom: 1rem;
    }

    .social-link {
      display: inline-flex;
      align-items: center;
      font-size: 0.75rem;
      line-height: 1;
      color: {{themeColor}};
      text-decoration: none;
    }

    .social-link:hover {
      text-decoration: underline;
    }

    .social-icon {
      width: 1rem;
      height: 1rem;
      margin-right: 0.25rem;
      fill: currentColor;
      flex: 0 0 auto;
    }

    .social-icon-outline {
      width: 1rem;
      height: 1rem;
      margin-right: 0.25rem;
      fill: none;
      stroke: currentColor;
      stroke-width: 1.5;
      stroke-linecap: round;
      stroke-linejoin: round;
      flex: 0 0 auto;
    }

    .summary {
      position: relative;
      padding-left: 1rem;
      margin-bottom: 1rem;
    }

    .summary-border {
      position: absolute;
      left: 0;
      top: 0;
      bottom: 0;
      width: 0.25rem;
      background: {{themeColor}};
    }

    .summary-copy .bullet-list {
      color: #374151;
      font-size: 0.865rem;
      line-height: 1.625;
      font-style: italic;
    }

    .grid {
      display: table;
      width: 100%;
      table-layout: fixed;
      border-collapse: separate;
      border-spacing: 0;
    }

    .left-column,
    .right-column {
      display: table-cell;
      vertical-align: top;
    }

    .left-column {
      width: 60%;
      padding-right: 1rem;
    }

    .right-column {
      width: 40%;
      padding-left: 0;
    }

    .section {
      margin-bottom: 1rem;
    }

    .section-title {
      display: inline-block;
      margin: 0 0 0.5rem;
      padding-bottom: 0.25rem;
      border-bottom: 2px solid {{themeColor}};
      color: {{themeColor}};
      font-size: 1.125rem;
      line-height: 1.25;
      font-weight: 700;
      text-transform: uppercase;
    }

    .section-card {
      padding: 0.25rem;
      margin-bottom: 0.25rem;
      border-radius: 0.375rem;
      page-break-inside: avoid;
    }

    .item-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      flex-wrap: wrap;
      gap: 0.5rem;
    }

    .item-title {
      margin: 0;
      color: {{themeColor}};
      font-size: 1rem;
      line-height: 1.35;
      font-weight: 700;
    }

    .item-date-badge {
      display: inline-flex;
      align-items: center;
      padding: 0.125rem 0.5rem;
      border-radius: 9999px;
      border: 1px solid {{themeColorTransparent20}};
      background: #ffffff;
      color: {{themeColor}};
      font-size: 0.75rem;
      line-height: 1.2;
      white-space: nowrap;
    }

    .item-subtitle {
      margin: 0 0 0.25rem;
      color: #374151;
      font-size: 0.875rem;
      line-height: 1.4;
      font-weight: 500;
    }

    .item-subtitle-theme {
      color: {{themeColor}};
    }

    .item-location {
      margin: 0 0 0.25rem;
      color: #111827;
      font-size: 0.875rem;
      line-height: 1.4;
      font-weight: 500;
    }

    .tech-stack {
      margin: 0.25rem 0;
      color: #111827;
      font-size: 0.75rem;
      line-height: 1.4;
    }

    .tech-label {
      color: {{themeColor}};
      font-weight: 600;
    }

    .content-list .bullet-list {
      color: #374151;
      font-size: 0.8rem;
      line-height: 1.5;
      font-style: normal;
    }

    .bullet-list {
      margin: 0;
      padding-left: 1rem;
    }

    .bullet-list li {
      margin: 0 0 0.25rem;
    }

    .project-links {
      display: flex;
      flex-wrap: wrap;
      gap: 0.25rem;
    }

    .project-link {
      display: inline-flex;
      align-items: center;
      padding: 0.125rem 0.5rem;
      border-radius: 9999px;
      border: 1px solid {{themeColorTransparent20}};
      background: #ffffff;
      color: {{themeColor}};
      text-decoration: none;
      font-size: 0.75rem;
      line-height: 1.2;
      white-space: nowrap;
    }

    .project-link-icon {
      width: 0.75rem;
      height: 0.75rem;
      margin-right: 0.25rem;
      flex: 0 0 auto;
    }

    .education-meta {
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin: 0.25rem 0;
      font-size: 0.75rem;
    }

    .education-date {
      color: #4b5563;
    }

    .grade-badge {
      display: inline-flex;
      align-items: center;
      padding: 0.125rem 0.5rem;
      border-radius: 9999px;
      border: 1px solid {{themeColorTransparent20}};
      background: #ffffff;
      color: {{themeColor}};
      font-size: 0.75rem;
      line-height: 1.2;
      white-space: nowrap;
    }

    .education-description {
      margin: 0;
      color: #374151;
      font-size: 0.75rem;
      line-height: 1.4;
    }

    .skills-wrap {
      display: flex;
      flex-wrap: wrap;
      gap: 0.25rem;
    }

    .skill-pill {
      display: inline-flex;
      align-items: center;
      padding: 0.25rem 0.75rem;
      margin-bottom: 0.25rem;
      border-radius: 9999px;
      border: 1px solid {{themeColorTransparent30}};
      background: #ffffff;
      color: {{themeColor}};
      font-size: 0.75rem;
      line-height: 1;
      white-space: nowrap;
    }

    .cert-date-badge {
      display: inline-flex;
      align-items: center;
      padding: 0.125rem 0.5rem;
      border-radius: 0.375rem;
      background: {{themeColorTransparent10}};
      color: {{themeColor}};
      font-size: 0.75rem;
      line-height: 1.2;
      white-space: nowrap;
    }

    .cert-link {
      display: inline-flex;
      align-items: center;
      color: {{themeColor}};
      text-decoration: none;
      font-size: 0.75rem;
      line-height: 1.2;
    }

    .cert-link:hover {
      text-decoration: underline;
    }

    .cert-icon {
      width: 0.75rem;
      height: 0.75rem;
      margin-right: 0.25rem;
      fill: none;
      stroke: currentColor;
      stroke-width: 1.5;
      stroke-linecap: round;
      stroke-linejoin: round;
      flex: 0 0 auto;
    }

    .rich-text-box {
      padding: 0.25rem;
      border-radius: 0.375rem;
      color: #374151;
      font-size: 0.875rem;
      line-height: 1.5;
      page-break-inside: avoid;
    }

    .rich-text-box p {
      margin: 0 0 0.25rem;
    }

    .rich-text-box p:last-child {
      margin-bottom: 0;
    }

    .rich-text-box ul,
    .rich-text-box ol {
      margin: 0;
      padding-left: 1rem;
    }

    .rich-text-box li {
      margin-bottom: 0.25rem;
    }

    .plain-box {
      padding: 0.25rem;
      border-radius: 0.375rem;
      color: #374151;
      font-size: 0.875rem;
      line-height: 1.5;
      page-break-inside: avoid;
    }

    @media (min-width: 768px) {
      .header-card {
        display: table;
      }
    }

    @media (max-width: 767px) {
      .header-card,
      .header-identity,
      .contact-badges {
        display: block;
        width: 100%;
      }

      .header-identity {
        text-align: center;
      }

      .contact-badges {
        margin-top: 0.5rem;
        text-align: center;
      }

      .contact-badges-inner {
        justify-content: center;
        grid-template-columns: auto;
      }

      .grid {
        display: block;
      }

      .left-column,
      .right-column {
        display: block;
        width: 100%;
        padding-right: 0;
        padding-left: 0;
      }
    }

    @media print {
      html,
      body {
        width: 210mm;
      }

      .resume {
        box-shadow: none;
        border-radius: 0;
      }

      .grid {
        display: table !important;
        width: 100% !important;
        table-layout: fixed !important;
      }

      .left-column,
      .right-column {
        display: table-cell !important;
        vertical-align: top !important;
      }

      .left-column {
        width: 60% !important;
        padding-right: 1rem !important;
      }

      .right-column {
        width: 40% !important;
        padding-left: 0 !important;
      }

      .header-card {
        display: table !important;
        width: calc(100% - 3rem) !important;
        table-layout: fixed !important;
      }

      .header-identity {
        display: table-cell !important;
        width: 58% !important;
        vertical-align: middle !important;
        text-align: left !important;
      }

      .contact-badges {
        display: table-cell !important;
        width: 42% !important;
        vertical-align: middle !important;
        text-align: right !important;
      }

      .contact-badges-inner {
        display: inline-grid !important;
        grid-template-columns: auto auto !important;
        justify-content: end !important;
      }

      .section {
        page-break-inside: avoid;
      }
    }
  </style>
</head>
<body>
  <div class="resume">
    <div class="header">
      <div class="header-card">
        <div class="header-identity">
          <h1 class="header-name">{{firstName}} {{lastName}}</h1>
          {{#if jobTitle}}
            <h2 class="header-title">{{jobTitle}}</h2>
          {{/if}}
        </div>

        {{#if (or (or email phone) address)}}
          <div class="contact-badges">
            <div class="contact-badges-inner">
              {{#if email}}
                <div class="contact-badge">
                  <svg class="badge-icon" viewBox="0 0 24 24">
                    <path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                  <span>{{email}}</span>
                </div>
              {{/if}}

              {{#if phone}}
                <div class="contact-badge">
                  <svg class="badge-icon" viewBox="0 0 24 24">
                    <path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  </svg>
                  <span>{{phone}}</span>
                </div>
              {{/if}}

              {{#if address}}
                <div class="contact-badge contact-badge-address">
                  <svg class="badge-icon" viewBox="0 0 24 24">
                    <path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                  <span>{{address}}</span>
                </div>
              {{/if}}
            </div>
          </div>
        {{/if}}
      </div>
    </div>

    <div class="main-content">
      {{#if (or (or linkedinUrl githubUrl) portfolioUrl)}}
        <div class="social-links">
          {{#if linkedinUrl}}
            <a href="{{formatUrl linkedinUrl}}" target="_blank" rel="noopener noreferrer" class="social-link">
              <svg class="social-icon" viewBox="0 0 24 24">
                <path d="M4.98 3.5c0 1.381-1.11 2.5-2.48 2.5s-2.48-1.119-2.48-2.5c0-1.38 1.11-2.5 2.48-2.5s2.48 1.12 2.48 2.5zm.02 4.5h-5v16h5v-16zm7.982 0h-4.968v16h4.969v-8.399c0-4.67 6.029-5.052 6.029 0v8.399h4.988v-10.131c0-7.88-8.922-7.593-11.018-3.714v-2.155z" />
              </svg>
              LinkedIn
            </a>
          {{/if}}

          {{#if githubUrl}}
            <a href="{{formatUrl githubUrl}}" target="_blank" rel="noopener noreferrer" class="social-link">
              <svg class="social-icon" viewBox="0 0 24 24">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12z" />
              </svg>
              GitHub
            </a>
          {{/if}}

          {{#if portfolioUrl}}
            <a href="{{formatUrl portfolioUrl}}" target="_blank" rel="noopener noreferrer" class="social-link">
              <svg class="social-icon-outline" viewBox="0 0 24 24">
                <path d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
              </svg>
              Portfolio
            </a>
          {{/if}}
        </div>
      {{/if}}

      {{#if summary}}
        <div class="summary">
          <div class="summary-border"></div>
          <div class="summary-copy">
            {{{bulletList summary}}}
          </div>
        </div>
      {{/if}}

      <div class="grid">
        <div class="left-column">
          {{#if experience.length}}
            <div class="section">
              <h3 class="section-title">EXPERIENCE</h3>

              <div>
                {{#each experience}}
                  <div class="section-card">
                    <div class="item-header">
                      <h4 class="item-title">{{this.title}}</h4>
                      <span class="item-date-badge">
                        {{this.startDate}}{{#if this.startDate}}{{#if this.currentlyWorking}} - Present{{else}}{{#if this.endDate}} - {{this.endDate}}{{/if}}{{/if}}{{/if}}
                      </span>
                    </div>

                    <h5 class="item-location">
                      {{this.companyName}}{{#if (or this.city this.state)}}{{#if this.companyName}} | {{/if}}{{/if}}{{this.city}}{{#if this.city}}{{#if this.state}}, {{/if}}{{/if}}{{this.state}}
                    </h5>

                    {{#if this.workSummary}}
                      <div class="content-list">
                        {{{bulletList this.workSummary}}}
                      </div>
                    {{/if}}
                  </div>
                {{/each}}
              </div>
            </div>
          {{/if}}

          {{#if projects.length}}
            <div class="section">
              <h3 class="section-title">PROJECTS</h3>

              <div>
                {{#each projects}}
                  <div class="section-card">
                    <div class="item-header">
                      <h4 class="item-title">{{this.projectName}}</h4>
                      {{#if (or this.githubLink this.deployedLink)}}
                        <div class="project-links">
                          {{#if this.githubLink}}
                            <a href="{{formatUrl this.githubLink}}" target="_blank" rel="noopener noreferrer" class="project-link">
                              <svg class="project-link-icon" viewBox="0 0 24 24" fill="currentColor">
                                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
                              </svg>
                              Code
                            </a>
                          {{/if}}

                          {{#if this.deployedLink}}
                            <a href="{{formatUrl this.deployedLink}}" target="_blank" rel="noopener noreferrer" class="project-link">
                              <svg class="project-link-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                              </svg>
                              Demo
                            </a>
                          {{/if}}
                        </div>
                      {{/if}}
                    </div>

                    {{#if this.techStack}}
                      <p class="tech-stack">
                        <span class="tech-label">Technologies:</span> {{this.techStack}}
                      </p>
                    {{/if}}

                    {{#if this.projectSummary}}
                      <div class="content-list">
                        {{{bulletList this.projectSummary}}}
                      </div>
                    {{/if}}
                  </div>
                {{/each}}
              </div>
            </div>
          {{/if}}
        </div>

        <div class="right-column">
          {{#if education.length}}
            <div class="section">
              <h3 class="section-title">EDUCATION</h3>

              <div>
                {{#each education}}
                  <div class="section-card">
                    <h4 class="item-title">{{this.degree}}{{#if this.major}}{{#if this.degree}} in {{/if}}{{this.major}}{{/if}}</h4>
                    <h5 class="item-subtitle item-subtitle-theme">{{this.universityName}}</h5>

                    <div class="education-meta">
                      <span class="education-date">
                        {{this.startDate}}{{#if this.startDate}}{{#if this.endDate}} - {{this.endDate}}{{/if}}{{/if}}
                      </span>
                      {{#if this.grade}}
                        <span class="grade-badge">{{this.gradeType}}: {{this.grade}}</span>
                      {{/if}}
                    </div>

                    {{#if this.description}}
                      <p class="education-description">{{this.description}}</p>
                    {{/if}}
                  </div>
                {{/each}}
              </div>
            </div>
          {{/if}}

          {{#if skills.length}}
            <div class="section">
              <h3 class="section-title">SKILLS</h3>

              <div class="skills-wrap">
                {{#each skills}}
                  <span class="skill-pill">{{this.name}}</span>
                {{/each}}
              </div>
            </div>
          {{/if}}

          {{#if certifications.length}}
            <div class="section">
              <h3 class="section-title">CERTIFICATIONS</h3>

              <div>
                {{#each certifications}}
                  <div class="section-card">
                    <div class="item-header">
                      <h4 class="item-title">{{this.name}}</h4>
                      {{#if this.date}}
                        <span class="cert-date-badge">{{this.date}}</span>
                      {{/if}}
                    </div>

                    <div class="item-header">
                      <h5 class="item-subtitle">{{this.issuer}}</h5>
                      {{#if this.credentialLink}}
                        <a href="{{formatUrl this.credentialLink}}" target="_blank" rel="noopener noreferrer" class="cert-link">
                          <svg class="cert-icon" viewBox="0 0 24 24">
                            <path d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101" />
                            <path d="M10.172 13.828a4 4 0 005.656 0l4-4a4 4 0 10-5.656-5.656l-1.102 1.101" />
                          </svg>
                          View
                        </a>
                      {{/if}}
                    </div>
                  </div>
                {{/each}}
              </div>
            </div>
          {{/if}}

          {{#if additionalSections.length}}
            {{#each additionalSections}}
              <div class="section">
                <h3 class="section-title">{{this.title}}</h3>
                <div class="rich-text-box">
                  {{{this.content}}}
                </div>
              </div>
            {{/each}}
          {{/if}}

          {{#if hobbies}}
            <div class="section">
              <h3 class="section-title">HOBBIES</h3>
              <div class="plain-box">{{hobbies}}</div>
            </div>
          {{/if}}
        </div>
      </div>
    </div>
  </div>
</body>
</html>
