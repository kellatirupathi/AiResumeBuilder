<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{firstName}} {{lastName}}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    /* Base styles */
    @page {
      size: A4;
      margin: 15mm 0 15mm 0;
    }
    @page :first {
      margin-top: 0;
    }

    /* Pagination — fill page 1 first, then continue naturally on page 2 */
    /* Only keep small inline atoms intact (pills/badges) */
    .skill-tag, .skill-pill, .skill-item,
    .item-date-badge, .job-date, .grade-badge, .cert-date-badge, .cert-date {
      page-break-inside: avoid;
      break-inside: avoid;
    }
    /* Allow column cells to break across pages so content flows naturally */
    .left-column, .right-column,
    .main-column, .side-column,
    .main-left, .main-right,
    .sidebar, .main-content {
      page-break-inside: auto;
      break-inside: auto;
    }
    p, li {
      orphans: 3;
      widows: 3;
    }

    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
      line-height: 1.5;
      color: #333;
      margin: 0;
      padding: 0;
      background-color: white;
    }

    /* Outer container — frontend: shadow-xl bg-white p-5 pt-6 border-t-[0.5px] rounded-md */
    .resume {
      width: 210mm;
      margin: 0;
      padding: 24px 20px 20px 20px;          /* p-5 + extra 4px on top (pt-6) */
      background-color: white;
      box-sizing: border-box;
      border-top: 0.5px solid {{themeColor}}; /* border-t-[0.5px] themeColor */
      border-radius: 0.375rem;                /* rounded-md */
      /* box-shadow removed — was creating visible shadow band at bottom of page 2 in PDF */
    }

    /* Personal details (frontend: -mt-1 pt-0) */
    .personal-details {
      margin-top: -4px;
      padding-top: 0;
    }

    .name {
      font-size: 20px;             /* text-xl */
      font-weight: bold;
      text-align: center;
      margin: 0 0 1px 0;
      color: {{themeColor}};
    }

    .job-title {
      font-size: 14px;             /* text-sm */
      text-align: center;
      font-weight: 500;
      margin: 0 0 1px 0;
    }

    .address {
      font-size: 12px;             /* text-xs */
      text-align: center;
      font-weight: normal;
      color: {{themeColor}};
      margin: 0 0 1px 0;
    }

    .contact-info {
      display: flex;
      justify-content: center;
      align-items: center;
      flex-wrap: wrap;
      gap: 12px;                   /* gap-3 */
      margin-top: 4px;             /* mt-1 */
      font-size: 12px;             /* text-xs */
    }

    .contact-item {
      color: {{themeColor}};
      font-weight: normal;
      text-decoration: none;
    }

    .contact-separator {
      color: #9ca3af;              /* text-gray-400 */
      font-size: 12px;
    }

    .main-divider {
      border: none;
      border-top: 1.5px solid {{themeColor}};
      margin: 8px 0;               /* my-2 */
    }

    /* Summary (frontend: just <p class="text-xs">) */
    .summary {
      font-size: 12px;             /* text-xs */
      margin: 0;
    }

    /* Section styling (frontend: my-3 wrapper) */
    .section {
      margin-top: 12px;
      margin-bottom: 12px;
    }

    .section-header {
      margin-bottom: 1px;
    }

    .section-title {
      text-align: center;
      font-weight: bold;
      font-size: 14px;             /* text-sm */
      color: {{themeColor}};
      text-transform: uppercase;
      margin: 0 0 4px 0;           /* mb-1 */
    }

    .section-divider {
      border: none;
      border-top: 1px solid {{themeColor}};
      margin: 0;
    }

    /* Item spacing (frontend: first item mt-1 mb-2, rest mb-2) */
    .experience-item, .project-item, .education-item, .certification-item {
      margin-bottom: 8px;          /* mb-2 */
    }
    .experience-item:first-child,
    .project-item:first-child,
    .education-item:first-child,
    .certification-item:first-child {
      margin-top: 4px;             /* mt-1 */
    }

    /* Job title / project name / university name / cert name — sm bold themeColor */
    .item-title {
      font-weight: bold;
      font-size: 14px;             /* text-sm */
      margin: 0;
      color: {{themeColor}};
    }

    /* === EXPERIENCE — frontend: title on row 1; company/city + date on row 2 === */
    .experience-meta-row {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      font-size: 12px;             /* text-xs */
      gap: 8px;
    }
    .experience-company {
      flex: 1;
    }
    .experience-date {
      white-space: nowrap;
    }
    .item-description {
      font-size: 13px;
      line-height: 1.4;
      margin-top: 4px;             /* mt-1 */
    }
    .item-description p { margin: 0 0 4px 0; }
    .item-description p:last-child { margin-bottom: 0; }
    .item-description ul, .item-description ol {
      margin: 5px 0 5px 16px;
      padding-left: 4px;
      list-style: disc;
    }
    .item-description li { margin-bottom: 4px; }
    .item-description li::marker { color: #555; }

    /* === PROJECTS === */
    .project-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
    }
    .project-links {
      display: flex;
      gap: 8px;                    /* gap-2 */
    }
    .link-item {
      color: {{themeColor}};
      text-decoration: none;
      font-size: 12px;             /* text-xs */
    }
    .project-tech {
      font-size: 12px;             /* text-xs */
      margin: 0;
    }

    /* === EDUCATION — frontend: university on row 1; degree + date on row 2 === */
    .education-meta-row {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-top: 4px;             /* mt-1 */
      gap: 8px;
    }
    .education-degree {
      font-size: 12px;             /* text-xs */
      font-weight: 500;
      flex: 1;
      margin: 0;
    }
    .education-date {
      font-size: 12px;             /* text-xs */
      color: #4b5563;              /* text-gray-600 */
      display: flex;
      align-items: center;
      white-space: nowrap;
      margin-left: 8px;
    }
    .education-grade-row {
      font-size: 12px;
      margin-top: 4px;             /* mt-1 */
      display: flex;
      align-items: center;
    }
    .education-grade-icon {
      width: 12px;
      height: 12px;
      margin-right: 4px;
      color: #6b7280;              /* text-gray-500 */
    }
    .education-grade-pill {
      display: inline-flex;
      align-items: center;
      background-color: #f3f4f6;   /* bg-gray-100 */
      border-radius: 9999px;
      padding: 2px 8px;
      font-size: 12px;
    }
    .education-description {
      font-size: 12px;             /* text-xs */
      color: #374151;              /* text-gray-700 */
      margin: 4px 0 0 0;
    }

    /* === CERTIFICATIONS — frontend: 2 rows, name+date / issuer+view === */
    .cert-row-1 {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .cert-row-2 {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-top: 2px;             /* mt-0.5 */
    }
    .cert-issuer {
      font-size: 12px;             /* text-xs */
      color: #4b5563;              /* text-gray-600 */
      margin: 0;
    }
    .cert-date-display {
      display: flex;
      align-items: center;
      white-space: nowrap;
      font-size: 12px;
      color: #4b5563;              /* text-gray-600 */
    }
    .credential-link {
      font-size: 12px;
      color: {{themeColor}};
      text-decoration: underline;
      display: flex;
      align-items: center;
    }

    /* Icons (12px = h-3 w-3) */
    .icon {
      width: 12px;
      height: 12px;
      margin-right: 4px;
      display: inline-block;
      vertical-align: middle;
    }

    /* Skills (frontend: vertical flex column, text-xs each) */
    .skills-list {
      display: flex;
      flex-direction: column;
      margin-top: 4px;             /* mt-1 */
    }
    .skill-item {
      font-size: 12px;             /* text-xs */
      margin-bottom: 2px;          /* mb-0.5 */
    }

    /* Additional sections — frontend: text-xs mt-2 */
    .additional-content {
      font-size: 12px;
      margin-top: 8px;             /* mt-2 */
    }
    .additional-content p { margin: 0 0 4px 0; }
    .additional-content p:last-child { margin-bottom: 0; }
    .additional-content ul, .additional-content ol {
      margin: 0 0 4px 16px;
      padding-left: 0;
    }
    .additional-content li { margin-bottom: 2px; }
  </style>
</head>
<body>
  <div class="resume">
    <!-- Personal Details -->
    <div class="personal-details">
      <h1 class="name">{{firstName}} {{lastName}}</h1>
      {{#if jobTitle}}<h2 class="job-title">{{jobTitle}}</h2>{{/if}}
      {{#if address}}<h2 class="address">{{address}}</h2>{{/if}}

      <div class="contact-info">
        {{#if phone}}
          <span class="contact-item">{{phone}}</span>
          {{#if email}}<span class="contact-separator">•</span>{{/if}}
        {{/if}}

        {{#if email}}
          <span class="contact-item">{{email}}</span>
          {{#if githubUrl}}<span class="contact-separator">•</span>{{/if}}
        {{/if}}

        {{#if githubUrl}}
          <a href="{{formatUrl githubUrl}}" target="_blank" rel="noopener noreferrer" class="contact-item">GitHub</a>
          {{#if linkedinUrl}}<span class="contact-separator">•</span>{{/if}}
        {{/if}}

        {{#if linkedinUrl}}
          <a href="{{formatUrl linkedinUrl}}" target="_blank" rel="noopener noreferrer" class="contact-item">LinkedIn</a>
          {{#if portfolioUrl}}<span class="contact-separator">•</span>{{/if}}
        {{/if}}

        {{#if portfolioUrl}}
          <a href="{{formatUrl portfolioUrl}}" target="_blank" rel="noopener noreferrer" class="contact-item">Portfolio</a>
        {{/if}}
      </div>

      <hr class="main-divider">
    </div>

    <!-- Summary -->
    {{#if summary}}<p class="summary">{{summary}}</p>{{/if}}

    <!-- 1. Skills -->
    {{#if skills.length}}
      <div class="section">
        <div class="section-header">
          <h3 class="section-title">Skills</h3>
          <hr class="section-divider">
        </div>
        <div class="skills-list">
          {{#each skills}}
            <div class="skill-item">{{this.name}}</div>
          {{/each}}
        </div>
      </div>
    {{/if}}

    <!-- 2. Experience: title alone, then company + date row, then description -->
    {{#if experience.length}}
      <div class="section">
        <div class="section-header">
          <h3 class="section-title">Experience</h3>
          <hr class="section-divider">
        </div>
        {{#each experience}}
          <div class="experience-item">
            <h4 class="item-title">{{this.title}}</h4>
            <div class="experience-meta-row">
              <span class="experience-company">{{this.companyName}}{{#if this.city}}{{#if this.companyName}}, {{/if}}{{this.city}}{{/if}}{{#if this.state}}{{#if this.city}}, {{/if}}{{this.state}}{{/if}}</span>
              <span class="experience-date">{{formatDate this.startDate}}{{#if this.startDate}}{{#if this.currentlyWorking}} - Present{{else}}{{#if this.endDate}} - {{formatDate this.endDate}}{{/if}}{{/if}}{{/if}}</span>
            </div>
            <div class="item-description">{{{this.workSummary}}}</div>
          </div>
        {{/each}}
      </div>
    {{/if}}

    <!-- 3. Education: university alone, then degree + date row, then grade pill, then description -->
    {{#if education.length}}
      <div class="section">
        <div class="section-header">
          <h3 class="section-title">Education</h3>
          <hr class="section-divider">
        </div>
        {{#each education}}
          <div class="education-item">
            <h4 class="item-title">{{this.universityName}}</h4>
            <div class="education-meta-row">
              <h5 class="education-degree">{{#if this.degree}}{{this.degree}}{{/if}}{{#if this.major}}{{#if this.degree}} in {{/if}}{{this.major}}{{/if}}</h5>
              {{#if this.startDate}}
                <span class="education-date">
                  <svg class="icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                    <line x1="16" y1="2" x2="16" y2="6"></line>
                    <line x1="8" y1="2" x2="8" y2="6"></line>
                    <line x1="3" y1="10" x2="21" y2="10"></line>
                  </svg>
                  {{formatDate this.startDate}}{{#if this.endDate}} - {{formatDate this.endDate}}{{/if}}
                </span>
              {{/if}}
            </div>

            {{#if this.grade}}
              <div class="education-grade-row">
                <svg class="icon education-grade-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="8" r="7"></circle>
                  <polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"></polyline>
                </svg>
                <span class="education-grade-pill">{{this.gradeType}}: {{this.grade}}</span>
              </div>
            {{/if}}

            {{#if this.description}}<p class="education-description">{{this.description}}</p>{{/if}}
          </div>
        {{/each}}
      </div>
    {{/if}}

    <!-- 4. Projects -->
    {{#if projects.length}}
      <div class="section">
        <div class="section-header">
          <h3 class="section-title">Projects</h3>
          <hr class="section-divider">
        </div>
        {{#each projects}}
          <div class="project-item">
            <div class="project-header">
              <h4 class="item-title">{{this.projectName}}</h4>
              <div class="project-links">
                {{#if this.githubLink}}<a href="{{formatUrl this.githubLink}}" target="_blank" rel="noopener noreferrer" class="link-item">Code</a>{{/if}}
                {{#if this.deployedLink}}<a href="{{formatUrl this.deployedLink}}" target="_blank" rel="noopener noreferrer" class="link-item">Demo</a>{{/if}}
              </div>
            </div>
            {{#if this.techStack}}
              <p class="project-tech"><span>Tech: {{replaceSeparator this.techStack "," " | "}}</span></p>
            {{/if}}
            <div class="item-description">{{{this.projectSummary}}}</div>
          </div>
        {{/each}}
      </div>
    {{/if}}

    <!-- 5. Certifications: 2 rows -->
    {{#if certifications.length}}
      <div class="section">
        <div class="section-header">
          <h3 class="section-title">Certifications</h3>
          <hr class="section-divider">
        </div>
        {{#each certifications}}
          <div class="certification-item">
            <div class="cert-row-1">
              <h4 class="item-title">{{this.name}}</h4>
              {{#if this.date}}
                <span class="cert-date-display">
                  <svg class="icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                    <line x1="16" y1="2" x2="16" y2="6"></line>
                    <line x1="8" y1="2" x2="8" y2="6"></line>
                    <line x1="3" y1="10" x2="21" y2="10"></line>
                  </svg>
                  {{this.date}}
                </span>
              {{/if}}
            </div>
            <div class="cert-row-2">
              <h5 class="cert-issuer">{{this.issuer}}</h5>
              {{#if this.credentialLink}}
                <a href="{{formatUrl this.credentialLink}}" target="_blank" rel="noopener noreferrer" class="credential-link">
                  <svg class="icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path>
                    <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path>
                  </svg>
                  View
                </a>
              {{/if}}
            </div>
          </div>
        {{/each}}
      </div>
    {{/if}}

    <!-- 6. Additional Sections -->
    {{#if additionalSections.length}}
      {{#each additionalSections}}
        <div class="section">
          <div class="section-header">
            <h3 class="section-title">{{this.title}}</h3>
            <hr class="section-divider">
          </div>
          <div class="additional-content">{{{this.content}}}</div>
        </div>
      {{/each}}
    {{/if}}
  </div>
</body>
</html>
