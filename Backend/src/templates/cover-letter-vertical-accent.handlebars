<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>{{title}}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <style>
    @page { margin: 0; }
    * { box-sizing: border-box; }
    html, body { margin: 0; padding: 0; background: #ffffff; }
    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      color: #1f2937;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
      position: relative;
      min-height: 100vh;
    }
    .vbar {
      position: fixed;
      top: 0;
      left: 0;
      bottom: 0;
      width: 8px;
      background-color: {{themeColor}};
    }
    .content {
      margin-left: 8px;
      padding: 36px 36px 36px 32px;
    }
    h1.name {
      font-size: 26px;
      font-weight: 800;
      margin: 0;
      color: #111827;
      letter-spacing: -0.01em;
      line-height: 1.1;
    }
    p.job-title {
      font-size: 12px;
      margin: 4px 0 0 0;
      color: {{themeColor}};
      font-weight: 600;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }
    p.contact-line {
      font-size: 10.5px;
      color: #4b5563;
      margin: 8px 0 0 0;
    }
    .divider { height: 1px; background-color: #e5e7eb; margin: 20px 0; }
    .date-right {
      text-align: right;
      font-size: 10.5px;
      color: #6b7280;
      margin-bottom: 16px;
    }
    .recipient {
      margin-bottom: 16px;
      font-size: 11px;
      line-height: 1.5;
    }
    .recipient p { margin: 0; }
    .recipient p.name { font-weight: 700; }
    .recipient p.company { color: #4b5563; }
    .greeting { font-size: 11px; margin-bottom: 14px; }
    p.para {
      margin: 0 0 12px 0;
      text-align: justify;
      font-size: 11px;
      line-height: 1.55;
      color: #1f2937;
      page-break-inside: avoid;
    }
    .signature { margin-top: 24px; }
    .signature p.signoff { font-size: 11px; margin: 0 0 22px 0; }
    .signature p.sign-name { font-size: 12px; font-weight: 700; margin: 0; color: {{themeColor}}; }
  </style>
</head>
<body>
  <div class="vbar"></div>
  <div class="content">
    {{#if senderName}}<h1 class="name">{{senderName}}</h1>{{/if}}
    {{#if jobTitle}}<p class="job-title">{{jobTitle}}</p>{{/if}}

    {{#if senderEmail}}
      <p class="contact-line">{{senderEmail}}{{#if senderPhone}}&nbsp;&nbsp;&middot;&nbsp;&nbsp;{{senderPhone}}{{/if}}{{#if senderAddress}}&nbsp;&nbsp;&middot;&nbsp;&nbsp;{{senderAddress}}{{/if}}{{#if senderLinkedin}}&nbsp;&nbsp;&middot;&nbsp;&nbsp;{{senderLinkedin}}{{/if}}</p>
    {{else}}{{#if senderPhone}}
      <p class="contact-line">{{senderPhone}}{{#if senderAddress}}&nbsp;&nbsp;&middot;&nbsp;&nbsp;{{senderAddress}}{{/if}}{{#if senderLinkedin}}&nbsp;&nbsp;&middot;&nbsp;&nbsp;{{senderLinkedin}}{{/if}}</p>
    {{/if}}{{/if}}

    <div class="divider"></div>

    <div class="date-right">{{formattedDate}}</div>

    <div class="recipient">
      <p class="name">{{#if hiringManagerName}}{{hiringManagerName}}{{else}}Hiring Manager{{/if}}</p>
      {{#if companyName}}<p class="company">{{companyName}}</p>{{/if}}
    </div>

    {{#if generatedContent.greeting}}<p class="greeting">{{generatedContent.greeting}}</p>{{/if}}

    {{#if generatedContent.openingParagraph}}<p class="para">{{generatedContent.openingParagraph}}</p>{{/if}}
    {{#each generatedContent.bodyParagraphs}}<p class="para">{{this}}</p>{{/each}}
    {{#if generatedContent.closingParagraph}}<p class="para">{{generatedContent.closingParagraph}}</p>{{/if}}

    <div class="signature">
      {{#if generatedContent.signature}}<p class="signoff">{{generatedContent.signature}}</p>{{/if}}
      {{#if senderName}}<p class="sign-name">{{senderName}}</p>{{/if}}
    </div>
  </div>
</body>
</html>
