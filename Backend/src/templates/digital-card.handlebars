<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{firstName}} {{lastName}}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    /* Base styles - Matching DigitalCardTemplate */
    @page {
      size: A4;
      margin: 15mm 0 15mm 0;
    }
    @page :first {
      margin-top: 0;
    }

    /* Pagination — fill page 1 first, then continue naturally on page 2 */
    /* Only keep small inline atoms intact (pills/badges) */
    .skill-tag, .skill-pill, .skill-item,
    .item-date-badge, .job-date, .grade-badge, .cert-date-badge, .cert-date {
      page-break-inside: avoid;
      break-inside: avoid;
    }
    /* Allow column cells to break across pages so content flows naturally */
    .left-column, .right-column,
    .main-column, .side-column,
    .main-left, .main-right,
    .sidebar, .main-content {
      page-break-inside: auto;
      break-inside: auto;
    }
    p, li {
      orphans: 3;
      widows: 3;
    }
    
    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
      line-height: 1.5;
      color: #333;
      margin: 0;
      padding: 0;
      background-color: white;
      height: auto;
      min-height: auto;
    }
    
    .resume {
      width: 210mm;
      margin: 0;
      padding: 0;
      background-color: white;
      box-shadow: 0 1px 1px 0 rgba(0, 0, 0, 0.03);
      border-radius: 0.375rem;
      /* overflow:hidden REMOVED — was preventing pagination */
    }
    
    /* Header with simple elegant design */
    .header {
      padding: 1.5rem;
      border-bottom: 1px solid {{themeColor}}20;
    }
    
    .header-container {
      max-width: 56rem;
      margin-left: auto;
      margin-right: auto;
    }
    
    /* Name and title layout */
    .header-content {
      display: table;
      width: 100%;
      table-layout: fixed;
      margin-bottom: 0;                      /* removed gap above social links */
    }
    
    .name-title {
      display: table-cell;
      width: 64%;
      text-align: left;
      vertical-align: top;
      box-sizing: border-box;
      padding-right: 1rem;
    }
    
    .name {
      font-size: 1.875rem;
      font-weight: 300;
      letter-spacing: 0.025em;
      margin-bottom: 0.25rem;
      margin-top: 0;
      color: #111827;
    }
    
    .job-title {
      font-size: 1.125rem;
      font-weight: 300;
      letter-spacing: 0.025em;
      color: #6b7280;
      margin-top: 0;
    }
    
    /* Contact info in right column */
    .contact-info {
      display: table-cell;
      width: 36%;
      text-align: right;
      font-size: 0.875rem;
      color: #6b7280;
      line-height: 1.25;
      vertical-align: top;
      box-sizing: border-box;
    }
    
    .contact-item {
      margin-bottom: 0.125rem;
    }
    
    /* Horizontal divider with accent color */
    .divider {
      height: 1px;
      width: 4rem;
      margin: 0.75rem auto;
      background-color: {{themeColor}};
    }
    
    /* Social links centered */
    .social-links {
      display: flex;
      justify-content: center;
      gap: 1.5rem;
      margin-bottom: 0.75rem;
    }
    
    .social-link {
      color: #9ca3af;
      transition: color 0.2s;
    }
    
    .social-link:hover {
      color: #4b5563;
    }
    
    .social-icon {
      width: 1.25rem;
      height: 1.25rem;
      fill: currentColor;
    }
    
    .social-icon-outline {
      width: 1.25rem;
      height: 1.25rem;
      fill: none;
      stroke: currentColor;
      stroke-width: 1.5;
      stroke-linecap: round;
      stroke-linejoin: round;
    }
    
    /* Summary — no margin below (gap removed) */
    .summary {
      margin-bottom: 0;
    }
    
    .summary-text {
      font-size: 0.875rem;
      line-height: 1.625;
      text-align: center;
      color: #4b5563;
      max-width: 48rem;
      margin: 0 auto;
    }
    
    /* Main content */
    .main-content {
      padding: 0.5rem 1.5rem 1.5rem 1.5rem;   /* tightened top — was 1.5rem all */
    }
    
    .main-container {
      max-width: 56rem;
      margin-left: auto;
      margin-right: auto;
    }
    
    /* Grid layout - Reduced gap */
    .grid {
      display: table;
      width: 100%;
      table-layout: fixed;
    }

    .left-column,
    .right-column {
      display: table-cell;
      vertical-align: top;
      box-sizing: border-box;
    }

    .left-column {
      width: 33.3333%;
      padding-right: 2rem;
    }

    .right-column {
      width: 66.6667%;
    }
    
    /* Sections */
    .section {
      margin-bottom: 1.5rem;
    }

    .section-title {
      font-size: 0.875rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      font-weight: 500;
      margin-bottom: 0.25rem;            /* tightened — was 1rem */
      padding-bottom: 0.25rem;
      border-bottom: 1px solid {{themeColor}}20;
      color: {{themeColor}};
    }
    
    /* Skills */
    .skills-container {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
    }

    .skill-tag {
      padding: 0.25rem 0.75rem;
      font-size: 0.75rem;
      border-radius: 0.375rem;
      border: 1px solid {{themeColor}}30;
      color: gray;
    }
    
    /* Education items */
    .education-item {
      margin-bottom: 0.75rem;
    }

    .education-title {
      font-size: 0.875rem;
      font-weight: 500;
      color: #1f2937;
      margin: 0;
    }

    .education-school {
      font-size: 0.75rem;
      color: #4b5563;
      margin: 0.125rem 0;
    }

    .education-date {
      font-size: 0.75rem;
      color: #6b7280;
    }

    .education-grade {
      font-size: 0.75rem;
      color: #374151;
      font-style: italic;
      margin-top: 0.125rem;
    }

    .education-description {
      font-size: 0.75rem;
      color: #4b5563;
      margin-top: 0.25rem;
    }
    
    /* Certification items */
    .certification-item {
      margin-bottom: 0.75rem;
    }

    .certification-title {
      font-size: 0.875rem;
      font-weight: 500;
      color: #1f2937;
      margin: 0;
    }

    .certification-meta {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin: 0.25rem 0;
    }

    .certification-issuer {
      font-size: 0.75rem;
      color: #4b5563;
    }

    .certification-link {
      font-size: 0.75rem;
      color: {{themeColor}};
      text-decoration: underline;
      margin-left: 0.5rem;
    }

    .certification-date {
      font-size: 0.75rem;
      color: #6b7280;
    }
    
    /* Experience items */
    .experience-item {
      margin-bottom: 1.25rem;
    }

    .experience-header {
      display: flex;
      flex-wrap: wrap;
      justify-content: space-between;
      align-items: baseline;
      margin-bottom: 0.25rem;
    }

    .experience-title {
      font-size: 1rem;
      font-weight: 500;
      color: #1f2937;
      margin: 0;
    }

    .experience-date {
      font-size: 0.75rem;
      color: #6b7280;
    }

    .experience-company {
      font-size: 0.875rem;
      color: #4b5563;
      margin-bottom: 0.5rem;
      font-style: italic;
    }

    .experience-description {
      font-size: 0.875rem;
      color: #374151;
      line-height: 1.5;
    }
    
    /* Project items — allowed to break across pages so content fills page 1 first */
    .project-item {
      margin-bottom: 1rem;
    }

    .project-header {
      display: flex;
      flex-wrap: wrap;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 0.25rem;
    }

    .project-title {
      font-size: 1rem;
      font-weight: 500;
      color: #1f2937;
      margin: 0;
    }

    .project-links {
      display: flex;
      gap: 0.75rem;
      font-size: 0.75rem;
    }

    .project-link {
      color: {{themeColor}};
      text-decoration: underline;
    }

    .project-tech {
      font-size: 0.75rem;
      color: #6b7280;
      margin-bottom: 0.25rem;
      font-style: italic;
    }

    .project-description {
      font-size: 0.875rem;
      color: #374151;
      line-height: 1.5;
    }

    .bullet-list {
      margin: 5px 0 5px 16px;
      padding-left: 4px;
      color: #374151;
      font-size: 13px;
      line-height: 1.4;
      list-style: disc;
    }

    .bullet-list li {
      margin-bottom: 4px;
    }

    .bullet-list li::marker {
      color: #555;
    }
    
    /* Additional sections */
    .additional-section {
      margin-bottom: 1.5rem;
    }

    .additional-content {
      font-size: 13px;
      line-height: 1.4;
      color: #374151;
    }

    .additional-content ul {
      margin: 0.25rem 0;
      padding-left: 1rem;
      margin-left: 1rem;
    }

    .additional-content li {
      margin-bottom: 0.25rem;
      list-style-type: disc;
    }

    .additional-content li::marker {
      color: #4b5563;
    }

    .additional-content p {
      margin-bottom: 0.5rem;
    }

    .additional-content h4 {
      font-weight: 500;
      font-size: 0.875rem;
      margin-bottom: 0.25rem;
    }

    .additional-content h5 {
      font-weight: 500;
      font-size: 0.75rem;
      margin-bottom: 0.25rem;
    }

    .additional-content strong {
      font-weight: 500;
    }
    
    /* Print-specific styles - Remove empty page creation */
    @media print {
      @page {
        size: A4;
        margin: 0;
      }
      
      .resume {
        box-shadow: none;
        border-radius: 0;
        width: 100%;
        height: auto;
        min-height: auto;
      }

      .header-content,
      .grid {
        display: table;
        width: 100%;
        table-layout: fixed;
      }

      .name-title,
      .contact-info,
      .left-column,
      .right-column {
        display: table-cell;
        vertical-align: top;
      }
      
      /* Allow natural page breaks within sections */
      .section {
        page-break-inside: auto;
      }
      
      /* Items allowed to break across pages — content fills page 1 first, then continues */
      
      /* Prevent orphaned section titles */
      .section-title {
        page-break-after: avoid;
      }
      
      /* Projects section should not force a page break */
      .projects-content {
        page-break-before: auto;
      }
      
      /* Remove any forced heights or spacing that create empty pages */
      body, html {
        height: auto !important;
        min-height: auto !important;
      }
      
      /* Ensure content-based height only */
      .main-content, .main-container, .grid, .left-column, .right-column {
        height: auto !important;
        min-height: auto !important;
      }
    }
  </style>
</head>
<body>
  <div class="resume">
    <!-- Header with simple elegant design -->
    <div class="header">
      <div class="header-container">
        <!-- Name and title -->
        <div class="header-content">
          <div class="name-title">
            <h1 class="name">{{firstName}} {{lastName}}</h1>
            {{#if jobTitle}}
              <h2 class="job-title">{{jobTitle}}</h2>
            {{/if}}
          </div>
          
          <!-- Contact info in right column -->
          <div class="contact-info">
            {{#if email}}
              <div class="contact-item">{{email}}</div>
            {{/if}}
            
            {{#if phone}}
              <div class="contact-item">{{phone}}</div>
            {{/if}}
            
            {{#if address}}
              <div class="contact-item">{{address}}</div>
            {{/if}}
          </div>
        </div>
        
        <!-- Social links centered -->
        <div class="social-links">
          {{#if linkedinUrl}}
            <a href="{{formatUrl linkedinUrl}}" target="_blank" rel="noopener noreferrer" class="social-link">
              <svg class="social-icon" viewBox="0 0 24 24">
                <path d="M4.98 3.5c0 1.381-1.11 2.5-2.48 2.5s-2.48-1.119-2.48-2.5c0-1.38 1.11-2.5 2.48-2.5s2.48 1.12 2.48 2.5zm.02 4.5h-5v16h5v-16zm7.982 0h-4.968v16h4.969v-8.399c0-4.67 6.029-5.052 6.029 0v8.399h4.988v-10.131c0-7.88-8.922-7.593-11.018-3.714v-2.155z" />
              </svg>
            </a>
          {{/if}}
          
          {{#if githubUrl}}
            <a href="{{formatUrl githubUrl}}" target="_blank" rel="noopener noreferrer" class="social-link">
              <svg class="social-icon" viewBox="0 0 24 24">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12z" />
              </svg>
            </a>
          {{/if}}
          
          {{#if portfolioUrl}}
            <a href="{{formatUrl portfolioUrl}}" target="_blank" rel="noopener noreferrer" class="social-link">
              <svg class="social-icon-outline" viewBox="0 0 24 24">
                <path d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
              </svg>
            </a>
          {{/if}}
        </div>
        
        <!-- Summary -->
        {{#if summary}}
          <div class="summary">
            <p class="summary-text">{{summary}}</p>
          </div>
        {{/if}}
      </div>
    </div>
    
    <!-- Main content -->
    <div class="main-content">
      <div class="main-container">
        <div class="grid">
          <!-- Left column - Skills & Education -->
          <div class="left-column">
            <!-- Skills -->
            {{#if skills.length}}
              <div class="section">
                <h3 class="section-title">Skills</h3>
                
                <div class="skills-container">
                  {{#each skills}}
                    <span class="skill-tag">{{this.name}}</span>
                  {{/each}}
                </div>
              </div>
            {{/if}}
            
            <!-- Education -->
            {{#if education.length}}
              <div class="section">
                <h3 class="section-title">Education</h3>
                
                <div class="education-content">
                  {{#each education}}
                    <div class="education-item">
                      <h4 class="education-title">
                        {{this.degree}}{{#if this.major}}{{#if this.degree}} in {{/if}}{{this.major}}{{/if}}
                      </h4>
                      
                      <div class="education-school">{{this.universityName}}</div>
                      
                      <div class="education-date">
                        {{this.startDate}}{{#if this.startDate}}{{#if this.endDate}} - {{this.endDate}}{{/if}}{{/if}}
                      </div>
                      
                      {{#if this.grade}}
                        <div class="education-grade">{{this.gradeType}}: {{this.grade}}</div>
                      {{/if}}
                      
                      {{#if this.description}}
                        <p class="education-description">{{this.description}}</p>
                      {{/if}}
                    </div>
                  {{/each}}
                </div>
              </div>
            {{/if}}
            
            <!-- Certifications -->
            {{#if certifications.length}}
              <div class="section">
                <h3 class="section-title">Certifications</h3>
                
                <div class="certifications-content">
                  {{#each certifications}}
                    <div class="certification-item">
                      <h4 class="certification-title">{{this.name}}</h4>
                      
                      <div class="certification-meta">
                        <span class="certification-issuer">{{this.issuer}}</span>
                        
                        {{#if this.credentialLink}}
                          <a href="{{formatUrl this.credentialLink}}" target="_blank" rel="noopener noreferrer" class="certification-link">
                            View
                          </a>
                        {{/if}}
                      </div>
                      
                      {{#if this.date}}
                        <div class="certification-date">{{this.date}}</div>
                      {{/if}}
                    </div>
                  {{/each}}
                </div>
              </div>
            {{/if}}
            
            <!-- Additional Sections - Flexible and styled to match template -->
            {{#each additionalSections}}
              <div class="section additional-section">
                <h3 class="section-title">{{this.title}}</h3>
                <div class="additional-content">{{{this.content}}}</div>
              </div>
            {{/each}}
          </div>
          
          <!-- Right column - Experience & Projects -->
          <div class="right-column">
            <!-- Experience -->
            {{#if experience.length}}
              <div class="section">
                <h3 class="section-title">Experience</h3>
                
                <div class="experience-content">
                  {{#each experience}}
                    <div class="experience-item">
                      <div class="experience-header">
                        <h4 class="experience-title">{{this.title}}</h4>
                        <span class="experience-date">
                          {{this.startDate}}{{#if this.startDate}}{{#if this.currentlyWorking}} - Present{{else}}{{#if this.endDate}} - {{this.endDate}}{{/if}}{{/if}}{{/if}}
                        </span>
                      </div>
                      
                      <div class="experience-company">
                        {{this.companyName}}
                        {{#if this.city}}{{#if this.companyName}}, {{/if}}{{this.city}}{{/if}}
                        {{#if this.state}}{{#if this.city}}, {{/if}}{{this.state}}{{/if}}
                      </div>
                      
                      {{{bulletList this.workSummary}}}
                    </div>
                  {{/each}}
                </div>
              </div>
            {{/if}}
            
            <!-- Projects -->
            {{#if projects.length}}
              <div class="section">
                <h3 class="section-title">Projects</h3>
                
                <div class="projects-content">
                  {{#each projects}}
                    <div class="project-item">
                      <div class="project-header">
                        <h4 class="project-title">{{this.projectName}}</h4>
                        
                        <div class="project-links">
                          {{#if this.githubLink}}
                            <a href="{{formatUrl this.githubLink}}" target="_blank" rel="noopener noreferrer" class="project-link">
                              GitHub
                            </a>
                          {{/if}}
                          
                          {{#if this.deployedLink}}
                            <a href="{{formatUrl this.deployedLink}}" target="_blank" rel="noopener noreferrer" class="project-link">
                              Live Demo
                            </a>
                          {{/if}}
                        </div>
                      </div>
                      
                      {{#if this.techStack}}
                        <p class="project-tech">{{this.techStack}}</p>
                      {{/if}}
                      
                      {{{bulletList this.projectSummary}}}
                    </div>
                  {{/each}}
                </div>
              </div>
            {{/if}}
          </div>
        </div>
      </div>
    </div>
  </div>
</body>
</html>
