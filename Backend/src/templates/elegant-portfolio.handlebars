<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{firstName}} {{lastName}}</title>
  <style>
    @page {
      size: A4;
      margin: 0;
    }

    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
      line-height: 1.45;
      color: #374151;
      margin: 0;
      padding: 0;
      background: #ffffff;
    }

    .resume {
      width: 210mm;
      margin: 0;
      padding: 0;
      background: #ffffff;
      box-sizing: border-box;
      border-radius: 0.375rem;
      overflow: hidden;
      box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
    }

    .header {
      padding: 1.5rem;
      border-bottom: 1px solid #e5e7eb;
    }

    .header-inner,
    .content-inner {
      max-width: 56rem;
      margin: 0 auto;
    }

    .header-layout {
      display: table;
      width: 100%;
      table-layout: fixed;
    }

    .header-left,
    .header-right {
      display: table-cell;
      vertical-align: bottom;
    }

    .header-left {
      width: 64%;
      text-align: left;
      padding-right: 1rem;
      box-sizing: border-box;
    }

    .header-right {
      width: 36%;
      text-align: right;
    }

    .name {
      margin: 0 0 0.25rem;
      font-size: 2rem;
      font-weight: 500;
      letter-spacing: 0.025em;
      color: {{themeColor}};
    }

    .job-title {
      margin: 0;
      font-size: 1.125rem;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: #374151;
    }

    .contact-line {
      margin: 0 0 0.25rem;
      font-size: 0.875rem;
      color: #4b5563;
      white-space: normal;
    }

    .contact-item {
      display: inline-flex;
      align-items: center;
      justify-content: flex-end;
      gap: 0.5rem;
    }

    .icon {
      width: 1rem;
      height: 1rem;
      fill: none;
      stroke: {{themeColor}};
      stroke-width: 1.5;
      stroke-linecap: round;
      stroke-linejoin: round;
      vertical-align: middle;
      flex: 0 0 auto;
    }

    .social-links {
      margin-top: 0.35rem;
    }

    .social-link {
      display: inline-block;
      margin-left: 0.75rem;
      color: {{themeColor}};
      text-decoration: none;
    }

    .social-link:first-child {
      margin-left: 0;
    }

    .social-icon {
      width: 1rem;
      height: 1rem;
      fill: currentColor;
      vertical-align: middle;
    }

    .social-icon-outline {
      width: 1rem;
      height: 1rem;
      fill: none;
      stroke: currentColor;
      stroke-width: 1.5;
      stroke-linecap: round;
      stroke-linejoin: round;
      vertical-align: middle;
    }

    .content {
      padding: 1rem 1.5rem 0.75rem;
    }

    .summary {
      margin-bottom: 1rem;
    }

    .summary-text {
      margin: 0;
      font-size: 0.85rem;
      color: #4b5563;
      text-align: center;
      line-height: 1.7;
    }

    .body-layout {
      display: table;
      width: 100%;
      table-layout: fixed;
    }

    .left-column,
    .right-column {
      display: table-cell;
      vertical-align: top;
      box-sizing: border-box;
    }

    .left-column {
      width: 66.666%;
      padding-right: 2rem;
    }

    .right-column {
      width: 33.333%;
    }

    .section {
      margin-bottom: 1.25rem;
    }

    .section-title {
      margin: 0 0 0.8rem;
      padding-bottom: 0.35rem;
      font-size: 1.125rem;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: {{themeColor}};
      border-bottom: 1px solid #e5e7eb;
    }

    .entry {
      margin-bottom: 1rem;
    }

    .entry:last-child {
      margin-bottom: 0;
    }

    .entry-header {
      display: table;
      width: 100%;
      table-layout: fixed;
      margin-bottom: 0.25rem;
    }

    .entry-title,
    .entry-meta {
      display: table-cell;
      vertical-align: baseline;
    }

    .entry-title {
      width: 68%;
      margin: 0;
      font-size: 1rem;
      font-weight: 500;
      color: {{themeColor}};
    }

    .entry-meta {
      width: 32%;
      text-align: right;
      font-size: 0.875rem;
      color: #6b7280;
    }

    .entry-subtitle {
      margin: 0 0 0.35rem;
      font-size: 0.875rem;
      font-weight: 500;
      color: #374151;
    }

    .entry-text,
    .project-tech,
    .education-date,
    .education-grade,
    .certification-meta-text,
    .additional-content {
      font-size: 0.875rem;
      color: #4b5563;
      line-height: 1.6;
    }

    .project-tech {
      margin: 0 0 0.35rem;
    }

    .entry-list {
      margin: 0;
      padding-left: 1.2rem;
      color: #4b5563;
    }

    .entry-list li {
      margin-bottom: 0.2rem;
    }

    .bullet-list {
      margin: 0;
      padding-left: 1.2rem;
      color: #4b5563;
      font-size: 0.8rem;
      line-height: 1.6;
    }

    .bullet-list li {
      margin-bottom: 0.2rem;
    }

    .project-links {
      text-align: right;
    }

    .project-link,
    .certification-link {
      font-size: 0.75rem;
      color: {{themeColor}};
      text-decoration: underline;
      margin-left: 1rem;
    }

    .project-link:first-child {
      margin-left: 0;
    }

    .education-title,
    .certification-title {
      margin: 0 0 0.25rem;
      font-size: 1rem;
      font-weight: 500;
      color: {{themeColor}};
    }

    .education-school,
    .certification-issuer {
      margin: 0 0 0.2rem;
      font-size: 0.875rem;
      font-weight: 500;
      color: #374151;
    }

    .education-date,
    .education-grade {
      margin: 0 0 0.15rem;
    }

    .skills-list {
      margin: 0;
      padding: 0;
      list-style: none;
    }

    .skills-list li {
      margin-bottom: 0.2rem;
      font-size: 0.875rem;
      color: #4b5563;
    }

    .skills-list li:last-child {
      margin-bottom: 0;
    }

    .footer {
      padding: 0.25rem 1.5rem 0.75rem;
    }

    .footer-divider {
      width: 16rem;
      max-width: 100%;
      height: 1px;
      margin: 0 auto;
      background: #e5e7eb;
    }

    .additional-content ul {
      margin: 0.25rem 0;
      padding-left: 1.1rem;
    }

    .additional-content li {
      margin-bottom: 0.15rem;
    }

    @media print {
      .resume {
        box-shadow: none;
        border-radius: 0;
      }

      .entry,
      .section {
        page-break-inside: avoid;
      }
    }
  </style>
</head>
<body>
  <div class="resume">
    <div class="header">
      <div class="header-inner">
        <div class="header-layout">
          <div class="header-left">
            <h1 class="name">{{firstName}} {{lastName}}</h1>
            {{#if jobTitle}}
              <h2 class="job-title">{{jobTitle}}</h2>
            {{/if}}
          </div>
          <div class="header-right">
            {{#if email}}
              <div class="contact-line">
                <span class="contact-item">
                  <span>{{email}}</span>
                  <svg class="icon" viewBox="0 0 24 24">
                    <path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                </span>
              </div>
            {{/if}}
            {{#if phone}}
              <div class="contact-line">
                <span class="contact-item">
                  <span>{{phone}}</span>
                  <svg class="icon" viewBox="0 0 24 24">
                    <path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  </svg>
                </span>
              </div>
            {{/if}}
            {{#if address}}
              <div class="contact-line">
                <span class="contact-item">
                  <span>{{address}}</span>
                  <svg class="icon" viewBox="0 0 24 24">
                    <path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                </span>
              </div>
            {{/if}}
            <div class="social-links">
              {{#if linkedinUrl}}
                <a href="{{formatUrl linkedinUrl}}" target="_blank" rel="noopener noreferrer" class="social-link">
                  <svg class="social-icon" viewBox="0 0 24 24">
                    <path d="M4.98 3.5c0 1.381-1.11 2.5-2.48 2.5s-2.48-1.119-2.48-2.5c0-1.38 1.11-2.5 2.48-2.5s2.48 1.12 2.48 2.5zm.02 4.5h-5v16h5v-16zm7.982 0h-4.968v16h4.969v-8.399c0-4.67 6.029-5.052 6.029 0v8.399h4.988v-10.131c0-7.88-8.922-7.593-11.018-3.714v-2.155z" />
                  </svg>
                </a>
              {{/if}}
              {{#if githubUrl}}
                <a href="{{formatUrl githubUrl}}" target="_blank" rel="noopener noreferrer" class="social-link">
                  <svg class="social-icon" viewBox="0 0 24 24">
                    <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
                  </svg>
                </a>
              {{/if}}
              {{#if portfolioUrl}}
                <a href="{{formatUrl portfolioUrl}}" target="_blank" rel="noopener noreferrer" class="social-link">
                  <svg class="social-icon-outline" viewBox="0 0 24 24">
                    <path d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
                  </svg>
                </a>
              {{/if}}
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="content">
      <div class="content-inner">
        {{#if summary}}
          <div class="summary">
            <p class="summary-text">{{summary}}</p>
          </div>
        {{/if}}

        <div class="body-layout">
          <div class="left-column">
            {{#if experience.length}}
              <div class="section">
                <h3 class="section-title">Experience</h3>
                {{#each experience}}
                  <div class="entry">
                    <div class="entry-header">
                      <h4 class="entry-title">{{this.title}}</h4>
                      <div class="entry-meta">
                        {{this.startDate}}{{#if this.startDate}}{{#if (or this.endDate this.currentlyWorking)}} - {{/if}}{{/if}}{{#if this.currentlyWorking}}Present{{else}}{{this.endDate}}{{/if}}
                      </div>
                    </div>
                    <p class="entry-subtitle">
                      {{this.companyName}}{{#if this.city}}{{#if this.companyName}}, {{/if}}{{this.city}}{{/if}}{{#if this.state}}{{#if this.city}}, {{/if}}{{this.state}}{{/if}}
                    </p>
                    {{{bulletList this.workSummary}}}
                  </div>
                {{/each}}
              </div>
            {{/if}}

            {{#if projects.length}}
              <div class="section">
                <h3 class="section-title">Projects</h3>
                {{#each projects}}
                  <div class="entry">
                    <div class="entry-header">
                      <h4 class="entry-title">{{this.projectName}}</h4>
                      <div class="entry-meta project-links">
                        {{#if this.githubLink}}
                          <a href="{{formatUrl this.githubLink}}" target="_blank" rel="noopener noreferrer" class="project-link">Code</a>
                        {{/if}}
                        {{#if this.deployedLink}}
                          <a href="{{formatUrl this.deployedLink}}" target="_blank" rel="noopener noreferrer" class="project-link">Demo</a>
                        {{/if}}
                      </div>
                    </div>
                    {{#if this.techStack}}
                      <p class="project-tech">{{this.techStack}}</p>
                    {{/if}}
                    {{{bulletList this.projectSummary}}}
                  </div>
                {{/each}}
              </div>
            {{/if}}

            {{#if certifications.length}}
              <div class="section">
                <h3 class="section-title">Certifications</h3>
                {{#each certifications}}
                  <div class="entry">
                    <div class="entry-header">
                      <h4 class="certification-title">{{this.name}}</h4>
                      <div class="entry-meta">{{this.date}}</div>
                    </div>
                    <div class="entry-header">
                      <p class="certification-issuer">{{this.issuer}}</p>
                      <div class="entry-meta">
                        {{#if this.credentialLink}}
                          <a href="{{formatUrl this.credentialLink}}" target="_blank" rel="noopener noreferrer" class="certification-link">View</a>
                        {{/if}}
                      </div>
                    </div>
                  </div>
                {{/each}}
              </div>
            {{/if}}
          </div>

          <div class="right-column">
            {{#if education.length}}
              <div class="section">
                <h3 class="section-title">Education</h3>
                {{#each education}}
                  <div class="entry">
                    <h4 class="education-title">{{this.degree}}{{#if this.major}}{{#if this.degree}} in {{/if}}{{this.major}}{{/if}}</h4>
                    <p class="education-school">{{this.universityName}}</p>
                    <p class="education-date">{{this.startDate}}{{#if this.startDate}}{{#if this.endDate}} - {{this.endDate}}{{/if}}{{/if}}</p>
                    {{#if this.grade}}
                      <p class="education-grade">{{this.gradeType}}: {{this.grade}}</p>
                    {{/if}}
                  </div>
                {{/each}}
              </div>
            {{/if}}

            {{#if skills.length}}
              <div class="section">
                <h3 class="section-title">Skills</h3>
                <ul class="skills-list">
                  {{#each skills}}
                    <li>{{this.name}}</li>
                  {{/each}}
                </ul>
              </div>
            {{/if}}

            {{#if additionalSections.length}}
              {{#each additionalSections}}
                <div class="section">
                  <h3 class="section-title">{{this.title}}</h3>
                  <div class="additional-content">{{{this.content}}}</div>
                </div>
              {{/each}}
            {{/if}}
          </div>
        </div>
      </div>
    </div>

    <div class="footer">
      <div class="footer-divider"></div>
    </div>
  </div>
</body>
</html>
