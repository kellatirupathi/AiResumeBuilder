<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{firstName}} {{lastName}}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    @page {
      size: A4;
      margin: 15mm 0 15mm 0;
    }
    @page :first {
      margin-top: 0;
    }

    /* Pagination — fill page 1 first, then continue naturally on page 2 */
    /* Only keep small inline atoms intact (pills/badges) */
    .skill-tag, .skill-pill, .skill-item,
    .item-date-badge, .job-date, .grade-badge, .cert-date-badge, .cert-date {
      page-break-inside: avoid;
      break-inside: avoid;
    }
    /* Allow column cells to break across pages so content flows naturally */
    .left-column, .right-column,
    .main-column, .side-column,
    .main-left, .main-right,
    .sidebar, .main-content {
      page-break-inside: auto;
      break-inside: auto;
    }
    p, li {
      orphans: 3;
      widows: 3;
    }

    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
      line-height: 1.4;
      color: #333333;
      margin: 0;
      padding: 0;
      background: #ffffff;
    }

    .resume {
      width: 210mm;
      margin: 0;
      padding: 0;
      background: #ffffff;
      border: 1px solid #e5e7eb;
      border-radius: 0.375rem;
      /* overflow:hidden REMOVED — was preventing pagination */
      box-sizing: border-box;
      box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
    }

    .header {
      padding: 0.75rem;
    }

    .header-content {
      text-align: center;
    }

    .name {
      margin: 0 0 0.125rem;
      font-size: 1.5rem;
      font-weight: 700;
    }

    .job-title {
      margin: 0 0 0.5rem;
      font-size: 1.125rem;
      color: #4b5563;
    }

    .contact-row {
      margin-bottom: 0.5rem;
      text-align: center;
      font-size: 0.875rem;
      color: #111827;
    }

    .contact-item {
      display: inline-flex;
      align-items: center;
      margin: 0 0.35rem 0.25rem;
      gap: 0.25rem;
    }

    .contact-icon {
      width: 1rem;
      height: 1rem;
      color: #6b7280;
      fill: none;
      stroke: currentColor;
      stroke-width: 2;
      stroke-linecap: round;
      stroke-linejoin: round;
      flex: 0 0 auto;
    }

    .social-row {
      margin-bottom: 0.5rem;
      text-align: center;
      font-size: 0.875rem;
    }

    .social-link {
      display: inline-flex;
      align-items: center;
      margin: 0 0.35rem;
      gap: 0.15rem;
      text-decoration: none;
    }

    .linkedin-link {
      color: #2563eb;
    }

    .github-link {
      color: #1f2937;
    }

    .portfolio-link {
      color: #16a34a;
    }

    .social-icon {
      width: 1rem;
      height: 1rem;
      fill: currentColor;
    }

    .social-icon-outline {
      width: 1rem;
      height: 1rem;
      fill: none;
      stroke: currentColor;
      stroke-width: 2;
      stroke-linecap: round;
      stroke-linejoin: round;
    }

    .summary {
      border-top: 1px solid #e5e7eb;
      padding-top: 0.5rem;
      margin-top: 0.25rem;
    }

    .summary p {
      margin: 0;
      font-size: 0.875rem;
      color: #374151;
      line-height: 1.7;
    }

    .main-content {
      padding: 0.75rem;
      display: table;
      width: 100%;
      table-layout: fixed;
      box-sizing: border-box;
    }

    .left-column,
    .right-column {
      display: table-cell;
      vertical-align: top;
      box-sizing: border-box;
    }

    .left-column {
      width: 58.333%;
      padding-right: 0.5rem;
    }

    .right-column {
      width: 41.667%;
    }

    .section {
      margin-bottom: 0.5rem;
    }

    .section:last-child {
      margin-bottom: 0;
    }

    .section-title {
      margin: 0 0 0.45rem;
      padding-bottom: 0.25rem;
      border-bottom: 1px solid #e5e7eb;
      font-size: 1.125rem;
      font-weight: 700;
      color: #111827;
    }

    .experience-item,
    .project-item,
    .cert-item,
    .education-item {
      margin-bottom: 0.5rem;
    }

    .experience-item:last-child,
    .project-item:last-child,
    .cert-item:last-child,
    .education-item:last-child {
      margin-bottom: 0;
    }

    .exp-header,
    .project-header,
    .cert-header,
    .edu-details {
      display: table;
      width: 100%;
      table-layout: fixed;
    }

    .exp-title {
      margin: 0;
      font-size: 1rem;
      font-weight: 700;
      color: #111827;
    }

    .project-title,
    .cert-title,
    .edu-title {
      margin: 0;
      font-size: 1rem;
      font-weight: 500;
      color: #111827;
    }

    .exp-title-cell,
    .project-title-cell,
    .cert-title-cell {
      display: table-cell;
      vertical-align: top;
      width: 68%;
      padding-right: 0.5rem;
      box-sizing: border-box;
    }

    .exp-date-cell,
    .project-links-cell,
    .cert-date-cell {
      display: table-cell;
      vertical-align: top;
      width: 32%;
      text-align: right;
    }

    .cert-date,
    .edu-meta {
      font-size: 0.875rem;
      color: #4b5563;
    }

    /* Experience date — smaller than other dates */
    .exp-date {
      font-size: 0.6875rem;                /* 11px — reduced from 0.875rem (14px) */
      color: #4b5563;
    }

    .exp-company {
      margin: 0.125rem 0 0.25rem;
      font-size: 0.875rem;
      font-weight: 500;
      color: #374151;
    }

    .bullet-list {
      margin: 5px 0 5px 16px;
      padding-left: 4px;
      list-style: disc;
      font-size: 13px;
      color: #4b5563;
      line-height: 1.4;
    }

    .bullet-list li {
      margin-bottom: 4px;
    }

    .bullet-list li::marker {
      color: #555;
    }

    .project-links {
      text-align: right;
      white-space: nowrap;
    }

    .project-link {
      display: inline-flex;
      align-items: center;
      gap: 0.15rem;
      margin-left: 0.5rem;
      font-size: 0.75rem;
      text-decoration: none;
    }

    .project-link:first-child {
      margin-left: 0;
    }

    .code-link {
      color: #4b5563;
    }

    .demo-link {
      color: #2563eb;
    }

    .project-link-icon {
      width: 0.75rem;
      height: 0.75rem;
      flex: 0 0 auto;
    }

    .project-tech {
      margin: 0.2rem 0 0.25rem;
      font-size: 0.75rem;
      color: #6b7280;
    }

    .tech-label {
      font-weight: 500;
    }

    .cert-details {
      display: table;
      width: 100%;
      table-layout: fixed;
      margin-top: 0.15rem;
    }

    .cert-issuer-cell {
      display: table-cell;
      width: 70%;
      vertical-align: top;
    }

    .cert-link-cell {
      display: table-cell;
      width: 30%;
      vertical-align: top;
      text-align: right;
    }

    .cert-issuer {
      font-size: 0.875rem;
      font-weight: 500;
      color: #374151;
    }

    .cert-link {
      display: inline-flex;
      align-items: center;
      gap: 0.15rem;
      font-size: 0.75rem;
      color: #2563eb;
      text-decoration: none;
    }

    .cert-link-icon {
      width: 0.75rem;
      height: 0.75rem;
      flex: 0 0 auto;
    }

    .skills-container {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
    }

    .skill-tag {
      padding: 0.125rem 0.375rem;
      background: #f3f4f6;
      border-radius: 0.375rem;
      font-size: 0.875rem;
      color: #374151;
    }

    .edu-title {
      margin-bottom: 0.125rem;
    }

    .edu-school {
      margin: 0 0 0.125rem;
      font-size: 0.875rem;
      color: #374151;
    }

    .edu-details {
      font-size: 0.75rem;
      color: #6b7280;
      margin-bottom: 0.125rem;
    }

    .edu-details-left,
    .edu-details-right {
      display: table-cell;
      vertical-align: top;
    }

    .edu-details-left {
      width: 70%;
    }

    .edu-details-right {
      width: 30%;
      text-align: right;
    }

    .edu-description,
    .additional-content {
      margin: 0.2rem 0 0;
      font-size: 0.75rem;
      color: #4b5563;
      line-height: 1.5;
    }

    .additional-content ul {
      margin: 0.25rem 0;
      padding-left: 1.1rem;
    }

    .additional-content li {
      margin-bottom: 0.1rem;
    }

    @media print {
      .resume {
        box-shadow: none;
        border-radius: 0;
        border: none;
      }

      /* Items allowed to break across pages — content fills page 1 first */
    }
  </style>
</head>
<body>
  <div class="resume">
    <div class="header">
      <div class="header-content">
        <h1 class="name">{{firstName}} {{lastName}}</h1>
        {{#if jobTitle}}
          <h2 class="job-title">{{jobTitle}}</h2>
        {{/if}}

        <div class="contact-row">
          {{#if email}}
            <span class="contact-item">
              <svg class="contact-icon" viewBox="0 0 24 24">
                <path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              <span>{{email}}</span>
            </span>
          {{/if}}
          {{#if phone}}
            <span class="contact-item">
              <svg class="contact-icon" viewBox="0 0 24 24">
                <path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              <span>{{phone}}</span>
            </span>
          {{/if}}
          {{#if address}}
            <span class="contact-item">
              <svg class="contact-icon" viewBox="0 0 24 24">
                <path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              <span>{{address}}</span>
            </span>
          {{/if}}
        </div>

        <div class="social-row">
          {{#if linkedinUrl}}
            <a href="{{formatUrl linkedinUrl}}" target="_blank" rel="noopener noreferrer" class="social-link linkedin-link">
              <svg class="social-icon" viewBox="0 0 24 24">
                <path d="M4.98 3.5c0 1.381-1.11 2.5-2.48 2.5s-2.48-1.119-2.48-2.5c0-1.38 1.11-2.5 2.48-2.5s2.48 1.12 2.48 2.5zm.02 4.5h-5v16h5v-16zm7.982 0h-4.968v16h4.969v-8.399c0-4.67 6.029-5.052 6.029 0v8.399h4.988v-10.131c0-7.88-8.922-7.593-11.018-3.714v-2.155z"/>
              </svg>
              LinkedIn
            </a>
          {{/if}}
          {{#if githubUrl}}
            <a href="{{formatUrl githubUrl}}" target="_blank" rel="noopener noreferrer" class="social-link github-link">
              <svg class="social-icon" viewBox="0 0 24 24">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
              </svg>
              GitHub
            </a>
          {{/if}}
          {{#if portfolioUrl}}
            <a href="{{formatUrl portfolioUrl}}" target="_blank" rel="noopener noreferrer" class="social-link portfolio-link">
              <svg class="social-icon-outline" viewBox="0 0 24 24">
                <path d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
              </svg>
              Portfolio
            </a>
          {{/if}}
        </div>

        {{#if summary}}
          <div class="summary">
            <p>{{summary}}</p>
          </div>
        {{/if}}
      </div>
    </div>

    <div class="main-content">
      <div class="left-column">
        {{#if experience.length}}
          <div class="section">
            <h3 class="section-title">Experience</h3>
            {{#each experience}}
              <div class="experience-item">
                <div class="exp-header">
                  <div class="exp-title-cell">
                    <h4 class="exp-title">{{this.title}}</h4>
                  </div>
                  <div class="exp-date-cell">
                    <span class="exp-date">
                      {{this.startDate}}{{#if this.startDate}}{{#if (or this.endDate this.currentlyWorking)}} - {{/if}}{{/if}}{{#if this.currentlyWorking}}Present{{else}}{{this.endDate}}{{/if}}
                    </span>
                  </div>
                </div>
                <div class="exp-company">
                  {{this.companyName}}{{#if this.city}}{{#if this.companyName}}, {{/if}}{{this.city}}{{/if}}{{#if this.state}}{{#if this.city}}, {{/if}}{{this.state}}{{/if}}
                </div>
                {{{bulletList this.workSummary}}}
              </div>
            {{/each}}
          </div>
        {{/if}}

        {{#if projects.length}}
          <div class="section">
            <h3 class="section-title">Projects</h3>
            {{#each projects}}
              <div class="project-item">
                <div class="project-header">
                  <div class="project-title-cell">
                    <h4 class="project-title">{{this.projectName}}</h4>
                  </div>
                  <div class="project-links-cell">
                    <div class="project-links">
                      {{#if this.githubLink}}
                        <a href="{{formatUrl this.githubLink}}" target="_blank" rel="noopener noreferrer" class="project-link code-link">
                          <svg class="project-link-icon" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                          </svg>
                          Code
                        </a>
                      {{/if}}
                      {{#if this.deployedLink}}
                        <a href="{{formatUrl this.deployedLink}}" target="_blank" rel="noopener noreferrer" class="project-link demo-link">
                          <svg class="project-link-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                          </svg>
                          Demo
                        </a>
                      {{/if}}
                    </div>
                  </div>
                </div>
                {{#if this.techStack}}
                  <div class="project-tech"><span class="tech-label">Tech Stack: </span>{{this.techStack}}</div>
                {{/if}}
                {{{bulletList this.projectSummary}}}
              </div>
            {{/each}}
          </div>
        {{/if}}

      </div>

      <div class="right-column">
        {{#if skills.length}}
          <div class="section">
            <h3 class="section-title">Skills</h3>
            <div class="skills-container">
              {{#each skills}}
                <span class="skill-tag">{{this.name}}</span>
              {{/each}}
            </div>
          </div>
        {{/if}}

        {{#if education.length}}
          <div class="section">
            <h3 class="section-title">Education</h3>
            {{#each education}}
              <div class="education-item">
                <h4 class="edu-title">{{this.degree}}{{#if this.major}}{{#if this.degree}} in {{/if}}{{this.major}}{{/if}}</h4>
                <div class="edu-school">{{this.universityName}}</div>
                <div class="edu-details">
                  <div class="edu-details-left">
                    <span>{{this.startDate}}{{#if this.startDate}}{{#if this.endDate}} - {{/if}}{{/if}}{{this.endDate}}</span>
                  </div>
                  <div class="edu-details-right">
                    {{#if this.grade}}
                      <span>{{this.gradeType}}: {{this.grade}}</span>
                    {{/if}}
                  </div>
                </div>
                {{#if this.description}}
                  <p class="edu-description">{{this.description}}</p>
                {{/if}}
              </div>
            {{/each}}
          </div>
        {{/if}}

        {{#if certifications.length}}
          <div class="section">
            <h3 class="section-title">Certifications</h3>
            {{#each certifications}}
              <div class="cert-item">
                <div class="cert-header">
                  <div class="cert-title-cell">
                    <h4 class="cert-title">{{this.name}}</h4>
                  </div>
                  <div class="cert-date-cell">
                    {{#if this.date}}
                      <span class="cert-date">{{this.date}}</span>
                    {{/if}}
                  </div>
                </div>
                <div class="cert-details">
                  <div class="cert-issuer-cell">
                    <div class="cert-issuer">{{this.issuer}}</div>
                  </div>
                  <div class="cert-link-cell">
                    {{#if this.credentialLink}}
                      <a href="{{formatUrl this.credentialLink}}" target="_blank" rel="noopener noreferrer" class="cert-link">
                        <svg class="cert-link-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101" />
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.172 13.828a4 4 0 005.656 0l4-4a4 4 0 10-5.656-5.656l-1.102 1.101" />
                        </svg>
                        View
                      </a>
                    {{/if}}
                  </div>
                </div>
              </div>
            {{/each}}
          </div>
        {{/if}}

        {{#if additionalSections.length}}
          {{#each additionalSections}}
            <div class="section">
              <h3 class="section-title">{{this.title}}</h3>
              <div class="additional-content">{{{this.content}}}</div>
            </div>
          {{/each}}
        {{/if}}
      </div>
    </div>
  </div>
</body>
</html>
