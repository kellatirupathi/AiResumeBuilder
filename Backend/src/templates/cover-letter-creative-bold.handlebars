<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>{{title}}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Caveat:wght@600;700&display=swap" rel="stylesheet" />
  <style>
    @page { margin: 0; }
    * { box-sizing: border-box; }
    html, body { margin: 0; padding: 0; background: #ffffff; }
    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      color: #1f2937;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }
    .banner {
      background-color: {{themeColor}};
      padding: 30px 40px;
      border-bottom-left-radius: 24px;
      border-bottom-right-radius: 24px;
      color: #ffffff;
      text-align: center;
    }
    .banner h1.name {
      font-size: 32px;
      font-weight: 800;
      margin: 0;
      letter-spacing: -0.01em;
      color: #ffffff;
    }
    .banner p.job-title {
      font-size: 13px;
      margin-top: 6px;
      opacity: 0.7;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: #ffffff;
    }
    .body-section {
      padding: 24px 48px 48px 48px;
    }
    .contact-row {
      display: flex;
      flex-wrap: wrap;
      gap: 8px 20px;
      justify-content: center;
      margin-bottom: 32px;
    }
    .contact-item {
      font-size: 10.5px;
      color: #374151;
      display: inline-flex;
      align-items: center;
      gap: 6px;
    }
    .contact-icon {
      color: {{themeColor}};
      font-size: 12px;
    }
    .date-recipient {
      display: table;
      width: 100%;
      margin-bottom: 20px;
    }
    .date-recipient .recipient-cell {
      display: table-cell;
      font-size: 11px;
      line-height: 1.5;
      vertical-align: top;
    }
    .date-recipient .date-cell {
      display: table-cell;
      text-align: right;
      font-size: 11px;
      color: #6b7280;
      font-style: italic;
      vertical-align: top;
    }
    .date-recipient p { margin: 0; }
    .date-recipient p.name { font-weight: 700; color: {{themeColor}}; }
    .date-recipient p.company { color: #4b5563; }
    .greeting { font-size: 13px; font-weight: 600; color: #1f2937; margin: 0 0 14px 0; }
    p.para {
      margin: 0 0 12px 0;
      text-align: justify;
      font-size: 11px;
      line-height: 1.6;
      color: #1f2937;
      page-break-inside: avoid;
    }
    p.opening-drop::first-letter {
      float: left;
      font-size: 38px;
      line-height: 0.9;
      font-weight: 800;
      color: {{themeColor}};
      padding-right: 8px;
      padding-top: 4px;
    }
    .signature { margin-top: 24px; }
    .signature p.signoff { font-size: 11px; color: #1f2937; margin: 0 0 8px 0; }
    .signature p.cursive {
      font-family: 'Caveat', 'Brush Script MT', cursive;
      font-size: 28px;
      color: {{themeColor}};
      margin: 0;
      line-height: 1;
    }
  </style>
</head>
<body>
  <div class="banner">
    {{#if senderName}}<h1 class="name">{{senderName}}</h1>{{/if}}
    {{#if jobTitle}}<p class="job-title">{{jobTitle}}</p>{{/if}}
  </div>

  <div class="body-section">
    <div class="contact-row">
      {{#if senderEmail}}<span class="contact-item"><span class="contact-icon">&#9993;</span>{{senderEmail}}</span>{{/if}}
      {{#if senderPhone}}<span class="contact-item"><span class="contact-icon">&#9742;</span>{{senderPhone}}</span>{{/if}}
      {{#if senderAddress}}<span class="contact-item"><span class="contact-icon">&#8962;</span>{{senderAddress}}</span>{{/if}}
      {{#if senderLinkedin}}<span class="contact-item"><span class="contact-icon">in</span>{{senderLinkedin}}</span>{{/if}}
      {{#if senderPortfolio}}<span class="contact-item"><span class="contact-icon">&#127760;</span>{{senderPortfolio}}</span>{{/if}}
    </div>

    <div class="date-recipient">
      <div class="recipient-cell">
        <p class="name">{{#if hiringManagerName}}{{hiringManagerName}}{{else}}Hiring Manager{{/if}}</p>
        {{#if companyName}}<p class="company">{{companyName}}</p>{{/if}}
      </div>
      <div class="date-cell">{{formattedDate}}</div>
    </div>

    {{#if generatedContent.greeting}}<p class="greeting">{{generatedContent.greeting}}</p>{{/if}}

    {{#if generatedContent.openingParagraph}}
      <p class="para opening-drop">{{generatedContent.openingParagraph}}</p>
    {{/if}}

    {{#each generatedContent.bodyParagraphs}}<p class="para">{{this}}</p>{{/each}}
    {{#if generatedContent.closingParagraph}}<p class="para">{{generatedContent.closingParagraph}}</p>{{/if}}

    <div class="signature">
      {{#if generatedContent.signature}}<p class="signoff">{{generatedContent.signature}}</p>{{/if}}
      {{#if senderName}}<p class="cursive">{{senderName}}</p>{{/if}}
    </div>
  </div>
</body>
</html>
